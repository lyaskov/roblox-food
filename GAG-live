local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local lp = Players.LocalPlayer
local pg = lp:WaitForChild("PlayerGui")

-- =========================
-- SETTINGS
-- =========================
local DEBOUNCE_SECONDS = 0.3
local DEBOUNCE_GEAR_SECONDS = 1.2

local TIMER_POLL_INTERVAL = 1.0
local BATCH_AFTER_REFRESH_TIMEOUT = 5
local BATCH_WATCHDOG_INTERVAL = 1.0

-- =========================
-- EMIT
-- =========================
local function emit(tag, kind, payload)
	warn(tag .. "|" .. kind .. "|" .. HttpService:JSONEncode(payload))
end

-- =========================
-- TIMER PARSER
-- =========================
local function parseSeedTimerSeconds(text)
	text = tostring(text or "")

	local minutesText = string.match(text, "(%d+)%s*m")
	local secondsText = string.match(text, "(%d+)%s*s")

	if not minutesText and not secondsText then
		return nil
	end

	local minutes = tonumber(minutesText) or 0
	local seconds = tonumber(secondsText) or 0

	return minutes * 60 + seconds
end

-- =========================
-- SEED BATCH WATCHDOG
-- =========================
local waitingSeedBatchAfterCycle = false
local waitingSeedBatchStartedAt = 0
local waitingSeedBatchReason = nil

local function armSeedBatchWait(reason)
	waitingSeedBatchAfterCycle = true
	waitingSeedBatchStartedAt = os.time()
	waitingSeedBatchReason = tostring(reason or "unknown")
end

local function clearSeedBatchWait()
	waitingSeedBatchAfterCycle = false
	waitingSeedBatchStartedAt = 0
	waitingSeedBatchReason = nil
end

local function startSeedBatchWaitWatchdog()
	task.spawn(function()
		while true do
			task.wait(BATCH_WATCHDOG_INTERVAL)

			if waitingSeedBatchAfterCycle then
				local now = os.time()
				local diff = now - waitingSeedBatchStartedAt

				if diff >= BATCH_AFTER_REFRESH_TIMEOUT then
					local cycleReason = waitingSeedBatchReason
					clearSeedBatchWait()

					emit("SEED", "ERROR", {
						shop = "Seed_Shop",
						ts = now,
						msg = "No batch received after cycle event",
						wait_seconds = diff,
						timeout_seconds = BATCH_AFTER_REFRESH_TIMEOUT,
						reason = "batch_missing_after_cycle",
						cycle_reason = cycleReason,
					})
				end
			end
		end
	end)

	emit("SEED", "INFO", {
		ts = os.time(),
		msg = "Seed batch wait watchdog started",
		timeout_seconds = BATCH_AFTER_REFRESH_TIMEOUT,
	})
end

-- =========================
-- STATE
-- =========================
local batchSeq = {
	SEED = 0,
	GEAR = 0,
}

local dumpScheduled = {
	SEED = false,
	GEAR = false,
}

local lastSnapshotKey = {
	SEED = nil,
	GEAR = nil,
}

local hookedItems = setmetatable({}, { __mode = "k" })
local hookedScrollingFrames = setmetatable({}, { __mode = "k" })
local hookedGuis = setmetatable({}, { __mode = "k" })

-- =========================
-- FORCE GUI OPEN
-- =========================
local function keepGuiEnabled(tag, guiName)
	local gui = pg:WaitForChild(guiName)

	if gui:IsA("ScreenGui") then
		gui.Enabled = true

		gui:GetPropertyChangedSignal("Enabled"):Connect(function()
			if gui.Enabled == false then
				gui.Enabled = true

				emit(tag, "INFO", {
					ts = os.time(),
					shop = guiName,
					msg = guiName .. " forced Enabled = true",
				})
			end
		end)
	end

	local frame = gui:FindFirstChild("Frame")
	if frame and frame:IsA("GuiObject") then
		frame.Visible = true

		frame:GetPropertyChangedSignal("Visible"):Connect(function()
			if frame.Visible == false then
				frame.Visible = true

				emit(tag, "INFO", {
					ts = os.time(),
					shop = guiName,
					msg = guiName .. ".Frame forced Visible = true",
				})
			end
		end)
	end

	emit(tag, "INFO", {
		ts = os.time(),
		shop = guiName,
		msg = guiName .. " open watcher attached",
	})

	return gui
end

-- =========================
-- PATHS
-- =========================
local function getShopScrollingFrame(gui)
	local frame = gui:WaitForChild("Frame")
	local scrollingFrame = frame:WaitForChild("ScrollingFrame")
	return scrollingFrame
end

local function getSeedTimerLabel(seedGui)
	return seedGui
		:WaitForChild("Frame")
		:WaitForChild("Frame")
		:WaitForChild("Timer")
end

-- =========================
-- SNAPSHOT / DUMP SHOP
-- =========================
local function dumpShop(tag, guiName, scrollingFrame, reason)
	local ts = os.time()

	local items = {}
	local snapshotParts = {}

	for _, item in ipairs(scrollingFrame:GetChildren()) do
		local mainFrame = item:FindFirstChild("Main_Frame")

		if mainFrame then
			local stockText = mainFrame:FindFirstChild("Stock_Text")

			if stockText then
				local itemName = tostring(item.Name)
				local stock = tostring(stockText.Text)

				table.insert(items, {
					item_name = itemName,
					stock = stock,
				})

				table.insert(snapshotParts, itemName .. "=" .. stock)
			end
		end
	end

	table.sort(snapshotParts)
	local snapshotKey = table.concat(snapshotParts, "|")

	-- ВАЖНО:
	-- Для SEED watchdog должен понять, что batch попытался прийти,
	-- даже если содержимое полностью такое же и мы пропускаем вывод.
	if tag == "SEED" then
		clearSeedBatchWait()
	end

	if lastSnapshotKey[tag] == snapshotKey then
		emit(tag, "INFO", {
			shop = guiName,
			ts = ts,
			msg = "Batch skipped: no changes",
			reason = tostring(reason or "unknown"),
		})
		return
	end

	lastSnapshotKey[tag] = snapshotKey

	batchSeq[tag] += 1
	local batchId = batchSeq[tag]

	emit(tag, "BATCH_START", {
		shop = guiName,
		batch_id = batchId,
		ts = ts,
		reason = tostring(reason or "unknown"),
	})

	for _, data in ipairs(items) do
		emit(tag, "ITEM", {
			shop = guiName,
			batch_id = batchId,
			ts = ts,
			item_name = data.item_name,
			stock = data.stock,
		})
	end

	emit(tag, "BATCH_END", {
		shop = guiName,
		batch_id = batchId,
		ts = ts,
		items = #items,
	})
end

local function scheduleDump(tag, guiName, scrollingFrame, reason)
	if dumpScheduled[tag] then
		return
	end

	dumpScheduled[tag] = true

	local delaySeconds = DEBOUNCE_SECONDS
	if tag == "GEAR" then
		delaySeconds = DEBOUNCE_GEAR_SECONDS
	end

	task.delay(delaySeconds, function()
		dumpScheduled[tag] = false

		if scrollingFrame and scrollingFrame.Parent then
			dumpShop(tag, guiName, scrollingFrame, reason)
		else
			emit(tag, "INFO", {
				ts = os.time(),
				shop = guiName,
				msg = "Dump skipped: ScrollingFrame destroyed",
				reason = tostring(reason or "unknown"),
			})
		end
	end)
end

-- =========================
-- ITEM HOOK
-- =========================
local function hookItem(tag, guiName, itemFrame, scrollingFrame)
	if hookedItems[itemFrame] then
		return
	end

	local mainFrame = itemFrame:FindFirstChild("Main_Frame")
	if not mainFrame then
		return
	end

	local stockText = mainFrame:FindFirstChild("Stock_Text")
	if not stockText then
		return
	end

	hookedItems[itemFrame] = true

	stockText:GetPropertyChangedSignal("Text"):Connect(function()
		scheduleDump(tag, guiName, scrollingFrame, "Stock_Text changed")
	end)

	itemFrame:GetPropertyChangedSignal("Visible"):Connect(function()
		scheduleDump(tag, guiName, scrollingFrame, "Visibility changed")
	end)

	emit(tag, "INFO", {
		ts = os.time(),
		shop = guiName,
		msg = "Item hooked",
		item = itemFrame.Name,
	})

	scheduleDump(tag, guiName, scrollingFrame, "Item hooked")
end

-- =========================
-- SCROLLING FRAME HOOK
-- =========================
local function hookScrollingFrame(tag, guiName, scrollingFrame)
	if hookedScrollingFrames[scrollingFrame] then
		return
	end

	hookedScrollingFrames[scrollingFrame] = true

	for _, item in ipairs(scrollingFrame:GetChildren()) do
		hookItem(tag, guiName, item, scrollingFrame)
	end

	scrollingFrame.ChildAdded:Connect(function(item)
		task.wait(0.05)
		hookItem(tag, guiName, item, scrollingFrame)
		scheduleDump(tag, guiName, scrollingFrame, "ChildAdded")
	end)

	scrollingFrame.ChildRemoved:Connect(function()
		scheduleDump(tag, guiName, scrollingFrame, "ChildRemoved")
	end)

	emit(tag, "INFO", {
		ts = os.time(),
		shop = guiName,
		msg = "ScrollingFrame hooked",
		path = scrollingFrame:GetFullName(),
	})
end

-- =========================
-- SEED TIMER
-- =========================
local seedTimerStartedForGui = setmetatable({}, { __mode = "k" })

local function startSeedTimer(seedGui)
	if seedTimerStartedForGui[seedGui] then
		return
	end

	seedTimerStartedForGui[seedGui] = true

	local timerLabel = getSeedTimerLabel(seedGui)

	local lastText = nil
	local lastSeconds = nil

	task.spawn(function()
		while true do
			task.wait(TIMER_POLL_INTERVAL)

			if not timerLabel or not timerLabel.Parent then
				emit("SEED", "INFO", {
					ts = os.time(),
					shop = "Seed_Shop",
					msg = "Timer destroyed",
				})
				break
			end

			local text = tostring(timerLabel.Text)
			local seconds = parseSeedTimerSeconds(text)

			if text ~= lastText then
				lastText = text

				emit("SEED", "TIMER", {
					shop = "Seed_Shop",
					ts = os.time(),
					raw = text,
					seconds = seconds,
				})

				if seconds == 0 and lastSeconds ~= 0 then
					emit("SEED", "REFRESH", {
						shop = "Seed_Shop",
						ts = os.time(),
						raw = text,
						seconds = 0,
						reason = "timer_zero",
					})

					armSeedBatchWait("REFRESH")
				end

				if lastSeconds ~= nil and seconds ~= nil and seconds > lastSeconds then
					emit("SEED", "CYCLE_START", {
						shop = "Seed_Shop",
						ts = os.time(),
						raw = text,
						seconds = seconds,
						prev_seconds = lastSeconds,
						reason = "timer_increased",
					})

					armSeedBatchWait("CYCLE_START")
				end
			end

			lastSeconds = seconds
		end
	end)

	emit("SEED", "INFO", {
		ts = os.time(),
		shop = "Seed_Shop",
		msg = "Seed timer started",
	})
end

-- =========================
-- SHOP GUI HOOK
-- =========================
local function hookShopGui(tag, guiName, gui)
	if not gui or not gui.Parent then
		return
	end

	local scrollingFrame = getShopScrollingFrame(gui)

	hookScrollingFrame(tag, guiName, scrollingFrame)

	if tag == "SEED" then
		startSeedTimer(gui)
	end

	scheduleDump(tag, guiName, scrollingFrame, "startup")

	if hookedGuis[gui] then
		return
	end

	hookedGuis[gui] = true

	gui.DescendantAdded:Connect(function(d)
		if d:IsA("ScrollingFrame") and d.Name == "ScrollingFrame" then
			task.wait(0.05)
			hookScrollingFrame(tag, guiName, d)
			scheduleDump(tag, guiName, d, "New ScrollingFrame detected")
			return
		end

		if d:IsA("GuiObject") and d.Parent and d.Parent.Name == "ScrollingFrame" then
			task.wait(0.05)

			if d.Parent and d.Parent:IsA("ScrollingFrame") then
				hookItem(tag, guiName, d, d.Parent)
			end
		end
	end)

	emit(tag, "INFO", {
		ts = os.time(),
		shop = guiName,
		msg = guiName .. " hooked",
	})
end

local function hookShop(tag, guiName)
	local gui = keepGuiEnabled(tag, guiName)
	hookShopGui(tag, guiName, gui)
end

-- =========================
-- START
-- =========================
startSeedBatchWaitWatchdog()

hookShop("SEED", "Seed_Shop")
hookShop("GEAR", "Gear_Shop")

pg.ChildAdded:Connect(function(child)
	if child.Name == "Seed_Shop" then
		task.wait(0.1)
		local gui = keepGuiEnabled("SEED", "Seed_Shop")
		hookShopGui("SEED", "Seed_Shop", gui)

	elseif child.Name == "Gear_Shop" then
		task.wait(0.1)
		local gui = keepGuiEnabled("GEAR", "Gear_Shop")
		hookShopGui("GEAR", "Gear_Shop", gui)
	end
end)
