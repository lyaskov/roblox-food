local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local lp = Players.LocalPlayer
local pg = lp:WaitForChild("PlayerGui")

-- =========================
-- SETTINGS
-- =========================
local DEBOUNCE_SECONDS = 0.3
local TIMER_POLL_INTERVAL = 1.0

-- =========================
-- EMIT
-- =========================
local function emit(kind, payload)
	warn("SEED|" .. kind .. "|" .. HttpService:JSONEncode(payload))
end

-- =========================
-- PARSE TIMER
-- =========================
local function parseSeedTimerSeconds(text)
	text = tostring(text or "")

	local minutesText = string.match(text, "(%d+)%s*m")
	local secondsText = string.match(text, "(%d+)%s*s")

	if not minutesText and not secondsText then
		return nil
	end

	local minutes = tonumber(minutesText) or 0
	local seconds = tonumber(secondsText) or 0

	return minutes * 60 + seconds
end

-- =========================
-- FORCE GUI ENABLED
-- =========================
local function keepSeedShopEnabled()
	local seedGui = pg:WaitForChild("Seed_Shop")

	if seedGui:IsA("ScreenGui") then
		seedGui.Enabled = true

		seedGui:GetPropertyChangedSignal("Enabled"):Connect(function()
			if seedGui.Enabled == false then
				seedGui.Enabled = true

				emit("INFO", {
					ts = os.time(),
					msg = "Seed_Shop forced Enabled = true",
				})
			end
		end)

		emit("INFO", {
			ts = os.time(),
			msg = "Seed_Shop enabled watcher attached",
		})
	else
		emit("INFO", {
			ts = os.time(),
			msg = "Seed_Shop is not ScreenGui",
		})
	end

	return seedGui
end

-- =========================
-- GET SCROLLING FRAME
-- =========================
local function getScrollingFrame(seedGui)
	local frame = seedGui:WaitForChild("Frame")
	local scrollingFrame = frame:WaitForChild("ScrollingFrame")
	return scrollingFrame
end

-- =========================
-- TIMER
-- =========================
local timerStartedForGui = setmetatable({}, { __mode = "k" })

local function startSeedTimer(seedGui)
	if timerStartedForGui[seedGui] then
		return
	end
	timerStartedForGui[seedGui] = true

	local timerLabel = seedGui
		:WaitForChild("Frame")
		:WaitForChild("Frame")
		:WaitForChild("Timer")

	local lastText = nil
	local lastSeconds = nil

	task.spawn(function()
		while true do
			task.wait(TIMER_POLL_INTERVAL)

			if not timerLabel or not timerLabel.Parent then
				emit("INFO", {
					ts = os.time(),
					msg = "Timer destroyed",
				})
				break
			end

			local text = tostring(timerLabel.Text)
			local seconds = parseSeedTimerSeconds(text)

			if text ~= lastText then
				lastText = text

				emit("TIMER", {
					shop = "Seed_Shop",
					ts = os.time(),
					raw = text,
					seconds = seconds,
				})

				if seconds == 0 and lastSeconds ~= 0 then
					emit("REFRESH", {
						shop = "Seed_Shop",
						ts = os.time(),
						raw = text,
						seconds = 0,
						reason = "timer_zero",
					})
				end

				if lastSeconds ~= nil and seconds ~= nil and seconds > lastSeconds then
					emit("CYCLE_START", {
						shop = "Seed_Shop",
						ts = os.time(),
						raw = text,
						seconds = seconds,
						prev_seconds = lastSeconds,
						reason = "timer_increased",
					})
				end
			end

			lastSeconds = seconds
		end
	end)

	emit("INFO", {
		ts = os.time(),
		msg = "Seed timer started",
	})
end

-- =========================
-- DUMP LOGIC
-- =========================
local dumpScheduled = false
local batchSeq = 0

local function dumpSeedShop(scrollingFrame, reason)
	batchSeq += 1
	local batchId = batchSeq
	local ts = os.time()

	emit("BATCH_START", {
		shop = "Seed_Shop",
		batch_id = batchId,
		ts = ts,
		reason = tostring(reason or "unknown"),
	})

	local count = 0

	for _, item in ipairs(scrollingFrame:GetChildren()) do
		local mainFrame = item:FindFirstChild("Main_Frame")
		if mainFrame then
			local stockText = mainFrame:FindFirstChild("Stock_Text")
			if stockText then
				count += 1

				emit("ITEM", {
					shop = "Seed_Shop",
					batch_id = batchId,
					ts = ts,
					item_name = item.Name,
					stock = tostring(stockText.Text),
				})
			end
		end
	end

	emit("BATCH_END", {
		shop = "Seed_Shop",
		batch_id = batchId,
		ts = ts,
		items = count,
	})
end

local function scheduleDump(scrollingFrame, reason)
	if dumpScheduled then
		return
	end

	dumpScheduled = true

	task.delay(DEBOUNCE_SECONDS, function()
		dumpScheduled = false

		if scrollingFrame and scrollingFrame.Parent then
			dumpSeedShop(scrollingFrame, reason)
		else
			emit("INFO", {
				ts = os.time(),
				msg = "Dump skipped: ScrollingFrame destroyed",
				reason = tostring(reason or "unknown"),
			})
		end
	end)
end

-- =========================
-- ITEM HOOK
-- =========================
local hookedItems = setmetatable({}, { __mode = "k" })

local function hookItem(itemFrame, scrollingFrame)
	if hookedItems[itemFrame] then
		return
	end

	local mainFrame = itemFrame:FindFirstChild("Main_Frame")
	if not mainFrame then
		return
	end

	local stockText = mainFrame:FindFirstChild("Stock_Text")
	if not stockText then
		return
	end

	hookedItems[itemFrame] = true

	stockText:GetPropertyChangedSignal("Text"):Connect(function()
		scheduleDump(scrollingFrame, "Stock_Text changed")
	end)

	itemFrame:GetPropertyChangedSignal("Visible"):Connect(function()
		scheduleDump(scrollingFrame, "Visibility changed")
	end)

	emit("INFO", {
		ts = os.time(),
		msg = "Item hooked",
		item = itemFrame.Name,
	})

	scheduleDump(scrollingFrame, "Item hooked")
end

-- =========================
-- SHOP HOOK
-- =========================
local hookedScrollingFrames = setmetatable({}, { __mode = "k" })
local hookedGuis = setmetatable({}, { __mode = "k" })

local function hookSeedShopGui(seedGui)
	if not seedGui or not seedGui.Parent then
		return
	end

	local scrollingFrame = getScrollingFrame(seedGui)

	if not hookedScrollingFrames[scrollingFrame] then
		hookedScrollingFrames[scrollingFrame] = true

		for _, item in ipairs(scrollingFrame:GetChildren()) do
			hookItem(item, scrollingFrame)
		end

		scrollingFrame.ChildAdded:Connect(function(item)
			task.wait(0.05)
			hookItem(item, scrollingFrame)
			scheduleDump(scrollingFrame, "ChildAdded")
		end)

		scrollingFrame.ChildRemoved:Connect(function()
			scheduleDump(scrollingFrame, "ChildRemoved")
		end)

		emit("INFO", {
			ts = os.time(),
			msg = "ScrollingFrame hooked",
			path = scrollingFrame:GetFullName(),
		})
	end

	startSeedTimer(seedGui)
	scheduleDump(scrollingFrame, "startup")

	if not hookedGuis[seedGui] then
		hookedGuis[seedGui] = true

		seedGui.DescendantAdded:Connect(function(d)
			if d:IsA("GuiObject") and d.Parent and d.Parent.Name == "ScrollingFrame" then
				task.wait(0.05)
				hookItem(d, scrollingFrame)
			end

			if d:IsA("ScrollingFrame") and d.Name == "ScrollingFrame" then
				task.wait(0.05)

				emit("INFO", {
					ts = os.time(),
					msg = "New ScrollingFrame detected",
					path = d:GetFullName(),
				})

				if not hookedScrollingFrames[d] then
					hookedScrollingFrames[d] = true

					for _, item in ipairs(d:GetChildren()) do
						hookItem(item, d)
					end

					d.ChildAdded:Connect(function(item)
						task.wait(0.05)
						hookItem(item, d)
						scheduleDump(d, "ChildAdded")
					end)

					d.ChildRemoved:Connect(function()
						scheduleDump(d, "ChildRemoved")
					end)
				end

				scheduleDump(d, "New ScrollingFrame detected")
			end
		end)

		emit("INFO", {
			ts = os.time(),
			msg = "Seed_Shop hooked",
		})
	end
end

local function hookSeedShop()
	local seedGui = keepSeedShopEnabled()
	hookSeedShopGui(seedGui)
end

-- =========================
-- START
-- =========================
hookSeedShop()

pg.ChildAdded:Connect(function(child)
	if child.Name == "Seed_Shop" then
		task.wait(0.1)
		local seedGui = keepSeedShopEnabled()
		hookSeedShopGui(seedGui)
	end
end)
