local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local DataService = require(ReplicatedStorage.Modules.DataService)
local receiver = DataService.Receiver

-- =========================
-- EMIT
-- =========================
local function emit(tag, kind, payload)
	warn(tag .. "|" .. kind .. "|" .. HttpService:JSONEncode(payload))
end

-- =========================
-- DEBUG PRINT
-- =========================
local function debug(msg, data)
	warn("DEBUG|" .. msg .. "|" .. HttpService:JSONEncode(data or {}))
end

-- =========================
-- SAFE GET DATA
-- =========================
local function safeGetData()
	local ok, data = pcall(function()
		return DataService:GetData()
	end)

	if not ok then
		debug("GetData FAILED", { error = data })
		return nil
	end

	if not data then
		debug("GetData returned NIL")
	end

	return data
end

-- =========================
-- BATCH
-- =========================
local function emitBatch(tag, shopName, stocks)
	if not stocks then
		debug("emitBatch skipped: no stocks", { tag = tag, shop = shopName })
		return
	end

	local ts = os.time()

	emit(tag, "BATCH_START", {
		shop = shopName,
		ts = ts,
	})

	local count = 0

	for name, data in pairs(stocks) do
		local stock = data.Stock or data

		emit(tag, "ITEM", {
			shop = shopName,
			ts = ts,
			item_name = name,
			stock = stock,
		})

		count += 1
	end

	emit(tag, "BATCH_END", {
		shop = shopName,
		ts = ts,
		items = count,
	})
end

-- =========================
-- SNAPSHOT
-- =========================
local function emitSnapshot()
	debug("SNAPSHOT START")

	local data = safeGetData()
	if not data then return end

	debug("DATA KEYS", data)

	-- SEED
	if data.SeedStocks then
		debug("SeedStocks FOUND")

		if data.SeedStocks.Shop then
			debug("Seed Shop FOUND")
			emitBatch("SEED", "Seed_Shop", data.SeedStocks.Shop.Stocks)
		else
			debug("Seed Shop MISSING")
		end

		if data.SeedStocks.DailyDeals then
			emit("SEED", "DAILY_DEALS", {
				ts = os.time(),
				deals = data.SeedStocks.DailyDeals,
			})
		else
			debug("DailyDeals MISSING")
		end
	else
		debug("SeedStocks NOT FOUND")
	end

	-- GEAR
	if data.GearStock then
		debug("GearStock FOUND")
		emitBatch("GEAR", "Gear_Shop", data.GearStock.Stocks)
	else
		debug("GearStock NOT FOUND")
	end

	-- PET
	if data.PetEggStock then
		debug("PetEggStock FOUND")
		emitBatch("PET", "PetShop_UI", data.PetEggStock)
	else
		debug("PetEggStock NOT FOUND")
	end

	-- EVENT
	if data.EventShopStock then
		debug("EventShopStock FOUND")
		emitBatch("EVENT", "Easter_Shop", data.EventShopStock.Stocks)
	else
		debug("EventShopStock NOT FOUND")
	end

	debug("SNAPSHOT END")
end

-- =========================
-- SUBSCRIBE
-- =========================
if receiver and receiver.GlobalChanged then
	debug("Receiver FOUND")

	receiver.GlobalChanged:Connect(function(key, newValue, oldValue, path)

		debug("CHANGE", {
			path = path,
			key = key
		})

		if not path then return end

		local data = safeGetData()
		if not data then return end

		-- SEED
		if string.find(path, "SeedStocks") then
			debug("Seed change detected")

			if data.SeedStocks and data.SeedStocks.Shop then
				emitBatch("SEED", "Seed_Shop", data.SeedStocks.Shop.Stocks)
			end
		end

		-- GEAR
		if string.find(path, "GearStock") then
			debug("Gear change detected")

			if data.GearStock then
				emitBatch("GEAR", "Gear_Shop", data.GearStock.Stocks)
			end
		end

		-- PET
		if string.find(path, "PetEggStock") then
			debug("Pet change detected")

			if data.PetEggStock then
				emitBatch("PET", "PetShop_UI", data.PetEggStock)
			end
		end

		-- EVENT
		if string.find(path, "EventShopStock") then
			debug("Event change detected")

			if data.EventShopStock then
				emitBatch("EVENT", "Easter_Shop", data.EventShopStock.Stocks)
			end
		end

	end)

	debug("Subscription active!")
else
	debug("Receiver NOT FOUND")
end

-- =========================
-- WEATHER
-- =========================
local GameEvents = ReplicatedStorage:WaitForChild("GameEvents")

local WeatherEventStarted = GameEvents:WaitForChild("WeatherEventStarted")
local SendClientWeatherEvents = GameEvents:WaitForChild("SendClientWeatherEvents")

WeatherEventStarted.OnClientEvent:Connect(function(weatherName, duration)
	emit("WEATHER", "START", {
		ts = os.time(),
		weather = weatherName,
		duration = duration,
	})
end)

SendClientWeatherEvents.OnClientEvent:Connect(function(weatherData, name, startTime)
	emit("WEATHER", "END", {
		ts = os.time(),
		weather = name,
		start_time = startTime,
	})
end)

debug("Weather subscription active!")

