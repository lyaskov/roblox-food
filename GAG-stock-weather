local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local DataService = require(ReplicatedStorage.Modules.DataService)
local receiver = DataService.Receiver

-- =========================
-- EMIT SAFE
-- =========================
local function emit(tag, kind, payload)
	local json = HttpService:JSONEncode(payload)
	local maxLen = 800

	if #json <= maxLen then
		warn(tag .. "|" .. kind .. "|" .. json)
		return
	end

	local total = math.ceil(#json / maxLen)

	for i = 1, total do
		local startIndex = ((i - 1) * maxLen) + 1
		local part = string.sub(json, startIndex, startIndex + maxLen - 1)

		warn(tag .. "|" .. kind .. "_PART|" .. i .. "/" .. total .. "|" .. part)
	end
end

local function debugLog(msg, data)
	emit("DEBUG", msg, data or {})
end

-- =========================
-- IGNORE NOISE
-- =========================
local ignoredPaths = {
	["SaveSlots/AllSlots/DEFAULT/LastSaveTime"] = true,
	["SaveSlots/AllSlots/DEFAULT/LastPetEggsIncubationTime"] = true,
	["SaveSlots/AllSlots/DEFAULT/LastObjectsSaveTime"] = true,
	["LastPetsSaveTime"] = true,
	["LastSaveTime"] = true,
	["LastPetsIncubationTime"] = true,
}

-- =========================
-- WEATHER STATE
-- =========================
local currentWeather = nil
local currentWeatherStartedAt = nil
local currentWeatherDuration = nil

-- =========================
-- HELPERS
-- =========================
local function safeGetData()
	local ok, data = pcall(function()
		return DataService:GetData()
	end)

	if not ok then
		debugLog("GET_DATA_FAILED", {
			error = tostring(data),
		})
		return nil
	end

	return data
end

local function getStockValue(data)
	if type(data) == "table" then
		return data.Stock
	end

	return data
end

local function getItemName(defaultName, data)
	if type(data) == "table" then
		return tostring(data.EggName or defaultName)
	end

	return tostring(defaultName)
end

local function emitBatch(tag, shopName, stocks, shopHash)
	if not stocks then
		debugLog("BATCH_SKIPPED_NO_STOCKS", {
			tag = tag,
			shop = shopName,
			shop_hash = shopHash,
		})
		return
	end

	local ts = os.time()
	local count = 0

	emit(tag, "BATCH_START", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
	})

	for name, data in pairs(stocks) do
		local stock = getStockValue(data)

		if stock ~= nil then
			emit(tag, "ITEM", {
				shop = shopName,
				ts = ts,
				cycle_id = ts,
				shop_hash = shopHash,
				slot = tostring(name),
				item_name = getItemName(name, data),
				stock = stock,
			})

			count += 1
		end
	end

	emit(tag, "BATCH_END", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
		items = count,
	})
end

local function emitDailyDeals(dailyDeals)
	if not dailyDeals then return end

	local ts = os.time()

	emit("SEED", "DAILY_DEALS_START", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = dailyDeals.Seed,
	})

	local count = 0

	for name, data in pairs(dailyDeals.Stocks or {}) do
		emit("SEED", "DAILY_DEAL_ITEM", {
			ts = ts,
			cycle_id = ts,
			shop = "Daily Deals",
			shop_hash = dailyDeals.Seed,
			item_name = tostring(name),
			stock = data.Stock,
			max_stock = data.MaxStock,
			is_good_seed = data.IsGoodSeed,
		})

		count += 1
	end

	emit("SEED", "DAILY_DEALS_END", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = dailyDeals.Seed,
		items = count,
	})
end

local function emitPetEggStock(petEggStock)
	if not petEggStock then return end

	emit("PET", "SEED", {
		ts = os.time(),
		shop = "PetShop_UI",
		egg = petEggStock.Egg,
		shop_hash = petEggStock.Egg,
	})

	emitBatch("PET", "PetShop_UI", petEggStock.Stocks, petEggStock.Egg)
end

local function emitWeatherCurrent()
	if currentWeather then
		local now = os.time()
		local elapsed = nil
		local remaining = nil

		if currentWeatherStartedAt then
			elapsed = now - currentWeatherStartedAt
		end

		if currentWeatherDuration and elapsed then
			remaining = math.max(0, currentWeatherDuration - elapsed)
		end

		emit("WEATHER", "CURRENT", {
			ts = now,
			weather = currentWeather,
			started_at = currentWeatherStartedAt,
			duration = currentWeatherDuration,
			elapsed = elapsed,
			remaining = remaining,
		})
	else
		emit("WEATHER", "CURRENT", {
			ts = os.time(),
			weather = nil,
			active = false,
		})
	end
end

-- =========================
-- SNAPSHOT
-- =========================
local function emitSnapshot()
	local data = safeGetData()
	if not data then return end

	emit("SYSTEM", "SNAPSHOT_START", {
		ts = os.time(),
	})

	if data.SeedStocks then
		if data.SeedStocks.Shop then
			emitBatch(
				"SEED",
				"Seed_Shop",
				data.SeedStocks.Shop.Stocks,
				data.SeedStocks.Shop.Seed
			)
		end

		if data.SeedStocks["Daily Deals"] then
			emitDailyDeals(data.SeedStocks["Daily Deals"])
		end
	end

	if data.GearStock then
		emitBatch(
			"GEAR",
			"Gear_Shop",
			data.GearStock.Stocks,
			data.GearStock.Gear
		)
	end

	if data.PetEggStock then
		emitPetEggStock(data.PetEggStock)
	end

	if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
		emitBatch(
			"EVENT",
			"Easter Seed Shop",
			data.EventShopStock["Easter Seed Shop"].Stocks,
			data.EventShopStock["Easter Seed Shop"].ShopSeed
		)
	end

	emitWeatherCurrent()

	emit("SYSTEM", "SNAPSHOT_END", {
		ts = os.time(),
	})
end

-- =========================
-- REALTIME SUBSCRIBE
-- =========================
if receiver and receiver.GlobalChanged then
	receiver.GlobalChanged:Connect(function(key, newValue, oldValue, path)
		if not path then return end
		if ignoredPaths[path] then return end

		local data = safeGetData()
		if not data then return end

		if string.find(path, "SeedStocks/Shop/Stocks") then
			if data.SeedStocks and data.SeedStocks.Shop then
				emitBatch(
					"SEED",
					"Seed_Shop",
					data.SeedStocks.Shop.Stocks,
					data.SeedStocks.Shop.Seed
				)
			end
			return
		end

		if string.find(path, "SeedStocks/Daily Deals") then
			if data.SeedStocks and data.SeedStocks["Daily Deals"] then
				emitDailyDeals(data.SeedStocks["Daily Deals"])
			end
			return
		end

		if string.find(path, "GearStock/Stocks") then
			if data.GearStock then
				emitBatch(
					"GEAR",
					"Gear_Shop",
					data.GearStock.Stocks,
					data.GearStock.Gear
				)
			end
			return
		end

		if string.find(path, "PetEggStock") then
			if data.PetEggStock then
				emitPetEggStock(data.PetEggStock)
			end
			return
		end

		if string.find(path, "EventShopStock/Easter Seed Shop/Stocks") then
			if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
				emitBatch(
					"EVENT",
					"Easter Seed Shop",
					data.EventShopStock["Easter Seed Shop"].Stocks,
					data.EventShopStock["Easter Seed Shop"].ShopSeed
				)
			end
			return
		end
	end)

	debugLog("DATA_SUBSCRIPTION_ACTIVE")
else
	debugLog("RECEIVER_OR_GLOBAL_CHANGED_NOT_FOUND")
end

-- =========================
-- WEATHER
-- =========================
local GameEvents = ReplicatedStorage:WaitForChild("GameEvents")

local WeatherEventStarted = GameEvents:WaitForChild("WeatherEventStarted")
local SendClientWeatherEvents = GameEvents:WaitForChild("SendClientWeatherEvents")

WeatherEventStarted.OnClientEvent:Connect(function(weatherName, duration)
	local now = os.time()

	currentWeather = weatherName
	currentWeatherStartedAt = now
	currentWeatherDuration = duration

	emit("WEATHER", "START", {
		ts = now,
		weather = weatherName,
		duration = duration,
	})
end)

SendClientWeatherEvents.OnClientEvent:Connect(function(weatherData, name, startTime)
	local now = os.time()

	emit("WEATHER", "END", {
		ts = now,
		weather = name,
		start_time = startTime,
		last_weather = currentWeather,
	})

	currentWeather = nil
	currentWeatherStartedAt = nil
	currentWeatherDuration = nil
end)

debugLog("WEATHER_SUBSCRIPTION_ACTIVE")

-- =========================
-- START
-- =========================
task.wait(2)
emitSnapshot()
