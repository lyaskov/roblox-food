local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local DataService = require(ReplicatedStorage.Modules.DataService)
local receiver = DataService.Receiver

-- =========================
-- EMIT SAFE
-- =========================
local function emit(tag, kind, payload)
	local json = HttpService:JSONEncode(payload)
	local maxLen = 800

	if #json <= maxLen then
		warn(tag .. "|" .. kind .. "|" .. json)
		return
	end

	local total = math.ceil(#json / maxLen)

	for i = 1, total do
		local startIndex = ((i - 1) * maxLen) + 1
		local part = string.sub(json, startIndex, startIndex + maxLen - 1)

		warn(tag .. "|" .. kind .. "_PART|" .. i .. "/" .. total .. "|" .. part)
	end
end

-- =========================
-- IGNORE NOISE
-- =========================
local ignoredPaths = {
	["SaveSlots/AllSlots/DEFAULT/LastSaveTime"] = true,
	["SaveSlots/AllSlots/DEFAULT/LastPetEggsIncubationTime"] = true,
	["SaveSlots/AllSlots/DEFAULT/LastObjectsSaveTime"] = true,
	["LastPetsSaveTime"] = true,
	["LastSaveTime"] = true,
	["LastPetsIncubationTime"] = true,
}

-- =========================
-- WEATHER STATE
-- =========================
local currentWeather = nil
local currentWeatherStartedAt = nil
local currentWeatherDuration = nil
local weatherToken = 0

-- =========================
-- NIGHT STATE
-- =========================
local currentNight = nil
local currentNightStartedAt = nil
local currentNightDuration = nil
local nightToken = 0

-- =========================
-- DEDUP
-- =========================
local lastShopHashes = {}

local function shouldSkipShop(tag, shopName, shopHash)
	if shopHash == nil then
		return false
	end

	local key = tag .. "|" .. shopName

	if lastShopHashes[key] == shopHash then
		return true
	end

	lastShopHashes[key] = shopHash
	return false
end

-- =========================
-- HELPERS
-- =========================
local function safeGetData()
	local ok, data = pcall(function()
		return DataService:GetData()
	end)

	if not ok or not data then
		return nil
	end

	return data
end

local function getStockValue(data)
	if type(data) == "table" then
		return data.Stock
	end

	return data
end

local function getItemName(defaultName, data)
	if type(data) == "table" then
		return tostring(data.EggName or defaultName)
	end

	return tostring(defaultName)
end

local function emitBatch(tag, shopName, stocks, shopHash, force)
	if not stocks then return end

	if not force and shouldSkipShop(tag, shopName, shopHash) then
		return
	end

	local ts = os.time()
	local count = 0

	emit(tag, "BATCH_START", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
	})

	for name, data in pairs(stocks) do
		local stock = getStockValue(data)

		if stock ~= nil then
			emit(tag, "ITEM", {
				shop = shopName,
				ts = ts,
				cycle_id = ts,
				shop_hash = shopHash,
				slot = tostring(name),
				item_name = getItemName(name, data),
				stock = stock,
			})

			count += 1
		end
	end

	emit(tag, "BATCH_END", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
		items = count,
	})
end

-- =========================
-- SHOP EMITTERS
-- =========================
local function emitDailyDeals(dailyDeals, force)
	if not dailyDeals then return end

	local shopHash = dailyDeals.Seed
	if not force and shouldSkipShop("SEED", "Daily Deals", shopHash) then
		return
	end

	local ts = os.time()
	local count = 0

	emit("SEED", "DAILY_DEALS_START", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = shopHash,
	})

	for name, data in pairs(dailyDeals.Stocks or {}) do
		emit("SEED", "DAILY_DEAL_ITEM", {
			ts = ts,
			cycle_id = ts,
			shop = "Daily Deals",
			shop_hash = shopHash,
			item_name = tostring(name),
			stock = data.Stock,
			max_stock = data.MaxStock,
			is_good_seed = data.IsGoodSeed,
		})

		count += 1
	end

	emit("SEED", "DAILY_DEALS_END", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = shopHash,
		items = count,
	})
end

local function emitPetEggStock(petEggStock, force)
	if not petEggStock then return end

	local shopHash = petEggStock.Egg

	if not force and shouldSkipShop("PET", "PetShop_UI", shopHash) then
		return
	end

	emit("PET", "SEED", {
		ts = os.time(),
		shop = "PetShop_UI",
		egg = petEggStock.Egg,
		shop_hash = shopHash,
	})

	emitBatch("PET", "PetShop_UI", petEggStock.Stocks, shopHash, true)
end

local function emitTravelingMerchantStock(merchantStock, force)
	if not merchantStock then return end

	local merchantType = tostring(merchantStock.MerchantType or "Traveling Merchant")
	local merchantStartTime = merchantStock.MerchantStartTime

	if not merchantStartTime or merchantStartTime == 0 then
		return
	end

	if not merchantStock.Stocks or next(merchantStock.Stocks) == nil then
		return
	end

	if not force and shouldSkipShop("MERCHANT", merchantType, merchantStartTime) then
		return
	end

	emit("MERCHANT", "INFO", {
		ts = os.time(),
		shop = merchantType,
		merchant_type = merchantType,
		merchant_start_time = merchantStartTime,
		shop_hash = merchantStartTime,
	})

	emitBatch("MERCHANT", merchantType, merchantStock.Stocks, merchantStartTime, true)
end

local function emitGardenCoinShop(gardenStock, force)
	if not gardenStock then return end

	local shopHash = gardenStock.LastRefreshed

	if not force and shouldSkipShop("GARDEN", "GardenCoinShop", shopHash) then
		return
	end

	emit("GARDEN", "INFO", {
		ts = os.time(),
		shop = "GardenCoinShop",
		last_refreshed = gardenStock.LastRefreshed,
		shop_hash = shopHash,
	})

	emitBatch("GARDEN", "GardenCoinShop", gardenStock.Stocks, shopHash, true)
end

local function emitSeasonPassStock(seasonPass, force)
	if not seasonPass then return end

	local seasonData = seasonPass["Season 4"]
	if not seasonData then return end

	local shopHash = seasonData.ShopItem

	if not force and shouldSkipShop("SEASON", "Season 4", shopHash) then
		return
	end

	emit("SEASON", "INFO", {
		ts = os.time(),
		shop = "Season 4",
		season = "Season 4",
		shop_hash = shopHash,
		total_experience = seasonData.TotalExperience,
		is_premium = seasonData.IsPremium,
		quest_reward_claimed = seasonData.QuestRewardClaimed,
		inf_rewards_claimed = seasonData.InfRewardsClaimed,
	})

	emitBatch("SEASON", "Season 4", seasonData.Stocks, shopHash, true)
end

local function emitWeatherCurrent()
	if currentWeather then
		local now = os.time()
		local elapsed = now - currentWeatherStartedAt
		local remaining = math.max(0, currentWeatherDuration - elapsed)

		emit("WEATHER", "CURRENT", {
			ts = now,
			active = true,
			weather = currentWeather,
			started_at = currentWeatherStartedAt,
			duration = currentWeatherDuration,
			elapsed = elapsed,
			remaining = remaining,
		})
	else
		emit("WEATHER", "CURRENT", {
			ts = os.time(),
			active = false,
		})
	end
end

-- =========================
-- SNAPSHOT
-- =========================
local function emitSnapshot()
	local data = safeGetData()
	if not data then return end

	emit("SYSTEM", "SNAPSHOT_START", {
		ts = os.time(),
	})

	if data.SeedStocks then
		if data.SeedStocks.Shop then
			emitBatch("SEED", "Seed_Shop", data.SeedStocks.Shop.Stocks, data.SeedStocks.Shop.Seed, true)
		end

		if data.SeedStocks["Daily Deals"] then
			emitDailyDeals(data.SeedStocks["Daily Deals"], true)
		end
	end

	if data.GearStock then
		emitBatch("GEAR", "Gear_Shop", data.GearStock.Stocks, data.GearStock.Gear, true)
	end

	if data.PetEggStock then
		emitPetEggStock(data.PetEggStock, true)
	end

	if data.TravelingMerchantShopStock then
		emitTravelingMerchantStock(data.TravelingMerchantShopStock, true)
	end

	if data.GardenCoinShopStock then
		emitGardenCoinShop(data.GardenCoinShopStock, true)
	end

	if data.SeasonPass then
		emitSeasonPassStock(data.SeasonPass, true)
	end

	if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
		emitBatch(
			"EVENT",
			"Easter Seed Shop",
			data.EventShopStock["Easter Seed Shop"].Stocks,
			data.EventShopStock["Easter Seed Shop"].ShopSeed,
			true
		)
	end

	emitWeatherCurrent()

	if currentNight then
		emit("NIGHT", "CURRENT", {
			ts = os.time(),
			active = true,
			started_at = currentNightStartedAt,
			duration = currentNightDuration,
		})
	end

	emit("SYSTEM", "SNAPSHOT_END", {
		ts = os.time(),
	})
end

-- =========================
-- REALTIME SUBSCRIBE
-- =========================
if receiver and receiver.GlobalChanged then
	receiver.GlobalChanged:Connect(function(key, newValue, oldValue, path)
		if not path then return end
		if ignoredPaths[path] then return end

		local data = safeGetData()
		if not data then return end

		if string.find(path, "SeedStocks/Shop/Stocks") or string.find(path, "SeedStocks/Shop/Seed") then
			if data.SeedStocks and data.SeedStocks.Shop then
				emitBatch("SEED", "Seed_Shop", data.SeedStocks.Shop.Stocks, data.SeedStocks.Shop.Seed)
			end
			return
		end

		if string.find(path, "SeedStocks/Daily Deals") then
			if data.SeedStocks and data.SeedStocks["Daily Deals"] then
				emitDailyDeals(data.SeedStocks["Daily Deals"])
			end
			return
		end

		if string.find(path, "GearStock/Stocks") or string.find(path, "GearStock/Gear") then
			if data.GearStock then
				emitBatch("GEAR", "Gear_Shop", data.GearStock.Stocks, data.GearStock.Gear)
			end
			return
		end

		if string.find(path, "PetEggStock") then
			if data.PetEggStock then
				emitPetEggStock(data.PetEggStock)
			end
			return
		end

		if string.find(path, "TravelingMerchantShopStock") then
			if data.TravelingMerchantShopStock then
				emitTravelingMerchantStock(data.TravelingMerchantShopStock)
			end
			return
		end

		if string.find(path, "GardenCoinShopStock") then
			if data.GardenCoinShopStock then
				emitGardenCoinShop(data.GardenCoinShopStock)
			end
			return
		end

		if string.find(path, "SeasonPass/Season 4") then
			if data.SeasonPass then
				emitSeasonPassStock(data.SeasonPass)
			end
			return
		end

		if string.find(path, "EventShopStock/Easter Seed Shop/Stocks") or string.find(path, "EventShopStock/Easter Seed Shop/ShopSeed") then
			if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
				emitBatch(
					"EVENT",
					"Easter Seed Shop",
					data.EventShopStock["Easter Seed Shop"].Stocks,
					data.EventShopStock["Easter Seed Shop"].ShopSeed
				)
			end
			return
		end
	end)
end

-- =========================
-- WEATHER
-- =========================
local GameEvents = ReplicatedStorage:WaitForChild("GameEvents")
local WeatherEventStarted = GameEvents:WaitForChild("WeatherEventStarted")
local SendClientWeatherEvents = GameEvents:WaitForChild("SendClientWeatherEvents")

WeatherEventStarted.OnClientEvent:Connect(function(weatherName, duration)
	local now = os.time()

	weatherToken += 1
	local myToken = weatherToken

	if currentWeather and currentWeather ~= weatherName then
		emit("WEATHER", "END", {
			ts = now,
			weather = currentWeather,
			started_at = currentWeatherStartedAt,
			duration = currentWeatherDuration,
			reason = "replaced_by_new_weather",
			next_weather = weatherName,
		})
	end

	currentWeather = weatherName
	currentWeatherStartedAt = now
	currentWeatherDuration = tonumber(duration)

	emit("WEATHER", "START", {
		ts = now,
		weather = weatherName,
		duration = currentWeatherDuration,
	})

	if currentWeatherDuration then
		task.delay(currentWeatherDuration + 2, function()
			if weatherToken == myToken and currentWeather == weatherName then
				emit("WEATHER", "END", {
					ts = os.time(),
					weather = weatherName,
					started_at = currentWeatherStartedAt,
					duration = currentWeatherDuration,
					reason = "duration_watchdog",
				})

				currentWeather = nil
				currentWeatherStartedAt = nil
				currentWeatherDuration = nil
			end
		end)
	end
end)

SendClientWeatherEvents.OnClientEvent:Connect(function(...)
	local args = { ... }
	local name = args[2]
	local startTime = args[3]

	weatherToken += 1

	emit("WEATHER", "END", {
		ts = os.time(),
		weather = name,
		start_time = startTime,
		last_weather = currentWeather,
		source = "SendClientWeatherEvents",
	})

	currentWeather = nil
	currentWeatherStartedAt = nil
	currentWeatherDuration = nil
end)

-- =========================
-- NIGHT
-- =========================
local NightStartedEvent = GameEvents:WaitForChild("NightStartedEvent")
local SendClientNightEvent = GameEvents:WaitForChild("SendClientNightEvent")

NightStartedEvent.OnClientEvent:Connect(function(duration)
	local now = os.time()

	nightToken += 1
	local myToken = nightToken

	if currentNight then
		emit("NIGHT", "END", {
			ts = now,
			started_at = currentNightStartedAt,
			duration = currentNightDuration,
			reason = "replaced_by_new_night",
		})
	end

	currentNight = true
	currentNightStartedAt = now
	currentNightDuration = tonumber(duration)

	emit("NIGHT", "START", {
		ts = now,
		duration = currentNightDuration,
	})

	if currentNightDuration then
		task.delay(currentNightDuration + 2, function()
			if nightToken == myToken and currentNight then
				emit("NIGHT", "END", {
					ts = os.time(),
					started_at = currentNightStartedAt,
					duration = currentNightDuration,
					reason = "duration_watchdog",
				})

				currentNight = nil
				currentNightStartedAt = nil
				currentNightDuration = nil
			end
		end)
	end
end)

SendClientNightEvent.OnClientEvent:Connect(function(...)
	nightToken += 1

	emit("NIGHT", "END", {
		ts = os.time(),
		source = "SendClientNightEvent",
	})

	currentNight = nil
	currentNightStartedAt = nil
	currentNightDuration = nil
end)

-- =========================
-- START
-- =========================
task.wait(2)
emitSnapshot()
