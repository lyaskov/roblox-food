local function dumpWeatherArgs(eventName, ...)
	local args = { ... }

	emit("WEATHER_DEBUG", eventName .. "_START", {
		ts = os.time(),
		argc = #args,
	})

	for i, arg in ipairs(args) do
		local value = arg

		if type(arg) ~= "table" then
			value = tostring(arg)
		end

		emit("WEATHER_DEBUG", eventName .. "_ARG", {
			ts = os.time(),
			index = i,
			value_type = type(arg),
			value = value,
		})
	end

	emit("WEATHER_DEBUG", eventName .. "_END", {
		ts = os.time(),
		argc = #args,
	})
end

WeatherEventStarted.OnClientEvent:Connect(function(weatherName, duration, ...)
	dumpWeatherArgs("WeatherEventStarted", weatherName, duration, ...)

	local now = os.time()

	weatherToken += 1
	local myToken = weatherToken

	currentWeather = weatherName
	currentWeatherStartedAt = now
	currentWeatherDuration = tonumber(duration)

	emit("WEATHER", "START", {
		ts = now,
		weather = weatherName,
		duration = tonumber(duration),
	})

	if currentWeatherDuration then
		task.delay(currentWeatherDuration + 2, function()
			if weatherToken == myToken and currentWeather == weatherName then
				emit("WEATHER", "END", {
					ts = os.time(),
					weather = weatherName,
					started_at = currentWeatherStartedAt,
					duration = currentWeatherDuration,
					reason = "duration_watchdog",
				})

				currentWeather = nil
				currentWeatherStartedAt = nil
				currentWeatherDuration = nil
			end
		end)
	end
end)

SendClientWeatherEvents.OnClientEvent:Connect(function(...)
	dumpWeatherArgs("SendClientWeatherEvents", ...)

	local args = { ... }
	local name = args[2]
	local startTime = args[3]

	weatherToken += 1

	emit("WEATHER", "END", {
		ts = os.time(),
		weather = name,
		start_time = startTime,
		last_weather = currentWeather,
		source = "SendClientWeatherEvents",
		raw_argc = #args,
	})

	currentWeather = nil
	currentWeatherStartedAt = nil
	currentWeatherDuration = nil
end)

debugLog("WEATHER_SUBSCRIPTION_ACTIVE")

