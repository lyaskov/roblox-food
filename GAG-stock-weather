-- =========================
local currentWeather = nil
local currentWeatherStartedAt = nil
local currentWeatherDuration = nil
local weatherToken = 0

-- =========================
-- HELPERS
-- =========================
local function safeGetData()
	local ok, data = pcall(function()
		return DataService:GetData()
	end)

	if not ok then
		debugLog("GET_DATA_FAILED", {
			error = tostring(data),
		})
		return nil
	end

	if not data then
		debugLog("GET_DATA_NIL", {
			ts = os.time(),
		})
		return nil
	end

	return data
end

local function getStockValue(data)
	if type(data) == "table" then
		return data.Stock
	end

	return data
end

local function getItemName(defaultName, data)
	if type(data) == "table" then
		return tostring(data.EggName or defaultName)
	end

	return tostring(defaultName)
end

local function emitBatch(tag, shopName, stocks, shopHash)
	if not stocks then
		debugLog("BATCH_SKIPPED_NO_STOCKS", {
			tag = tag,
			shop = shopName,
			shop_hash = shopHash,
		})
		return
	end

	local ts = os.time()
	local count = 0

	emit(tag, "BATCH_START", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
	})

	for name, data in pairs(stocks) do
		local stock = getStockValue(data)

		if stock ~= nil then
			emit(tag, "ITEM", {
				shop = shopName,
				ts = ts,
				cycle_id = ts,
				shop_hash = shopHash,
				slot = tostring(name),
				item_name = getItemName(name, data),
				stock = stock,
			})

			count += 1
		end
	end

	emit(tag, "BATCH_END", {
		shop = shopName,
		ts = ts,
		cycle_id = ts,
		shop_hash = shopHash,
		items = count,
	})
end

local function emitDailyDeals(dailyDeals)
	if not dailyDeals then return end

	local ts = os.time()

	emit("SEED", "DAILY_DEALS_START", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = dailyDeals.Seed,
	})

	local count = 0

	for name, data in pairs(dailyDeals.Stocks or {}) do
		emit("SEED", "DAILY_DEAL_ITEM", {
			ts = ts,
			cycle_id = ts,
			shop = "Daily Deals",
			shop_hash = dailyDeals.Seed,
			item_name = tostring(name),
			stock = data.Stock,
			max_stock = data.MaxStock,
			is_good_seed = data.IsGoodSeed,
		})

		count += 1
	end

	emit("SEED", "DAILY_DEALS_END", {
		ts = ts,
		cycle_id = ts,
		shop = "Daily Deals",
		shop_hash = dailyDeals.Seed,
		items = count,
	})
end

local function emitPetEggStock(petEggStock)
	if not petEggStock then return end

	emit("PET", "SEED", {
		ts = os.time(),
		shop = "PetShop_UI",
		egg = petEggStock.Egg,
		shop_hash = petEggStock.Egg,
	})

	emitBatch("PET", "PetShop_UI", petEggStock.Stocks, petEggStock.Egg)
end

local function emitTravelingMerchantStock(merchantStock)
	if not merchantStock then return end

	local merchantType = tostring(merchantStock.MerchantType or "Traveling Merchant")
	local merchantStartTime = merchantStock.MerchantStartTime

	emit("MERCHANT", "INFO", {
		ts = os.time(),
		shop = merchantType,
		merchant_type = merchantType,
		merchant_start_time = merchantStartTime,
		shop_hash = merchantStartTime,
	})

	emitBatch(
		"MERCHANT",
		merchantType,
		merchantStock.Stocks,
		merchantStartTime
	)
end

local function emitWeatherCurrent()
	if currentWeather then
		local now = os.time()
		local elapsed = nil
		local remaining = nil

		if currentWeatherStartedAt then
			elapsed = now - currentWeatherStartedAt
		end

		if currentWeatherDuration and elapsed then
			remaining = math.max(0, currentWeatherDuration - elapsed)
		end

		emit("WEATHER", "CURRENT", {
			ts = now,
			active = true,
			weather = currentWeather,
			started_at = currentWeatherStartedAt,
			duration = currentWeatherDuration,
			elapsed = elapsed,
			remaining = remaining,
		})
	else
		emit("WEATHER", "CURRENT", {
			ts = os.time(),
			active = false,
		})
	end
end

-- =========================
-- SNAPSHOT
-- =========================
local function emitSnapshot()
	debugLog("SNAPSHOT_FUNCTION_ENTER", {
		ts = os.time(),
	})

	local data = safeGetData()
	if not data then
		debugLog("SNAPSHOT_ABORT_NO_DATA", {
			ts = os.time(),
		})
		return
	end

	emit("SYSTEM", "SNAPSHOT_START", {
		ts = os.time(),
	})

	if data.SeedStocks then
		if data.SeedStocks.Shop then
			emitBatch(
				"SEED",
				"Seed_Shop",
				data.SeedStocks.Shop.Stocks,
				data.SeedStocks.Shop.Seed
			)
		else
			debugLog("SEED_SHOP_MISSING")
		end

		if data.SeedStocks["Daily Deals"] then
			emitDailyDeals(data.SeedStocks["Daily Deals"])
		else
			debugLog("DAILY_DEALS_MISSING")
		end
	else
		debugLog("SEED_STOCKS_MISSING")
	end

	if data.GearStock then
		emitBatch(
			"GEAR",
			"Gear_Shop",
			data.GearStock.Stocks,
			data.GearStock.Gear
		)
	else
		debugLog("GEAR_STOCK_MISSING")
	end

	if data.PetEggStock then
		emitPetEggStock(data.PetEggStock)
	else
		debugLog("PET_EGG_STOCK_MISSING")
	end

	if data.TravelingMerchantShopStock then
		emitTravelingMerchantStock(data.TravelingMerchantShopStock)
	else
		debugLog("TRAVELING_MERCHANT_STOCK_MISSING")
	end

	if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
		emitBatch(
			"EVENT",
			"Easter Seed Shop",
			data.EventShopStock["Easter Seed Shop"].Stocks,
			data.EventShopStock["Easter Seed Shop"].ShopSeed
		)
	else
		debugLog("EVENT_EASTER_SHOP_MISSING")
	end

	emitWeatherCurrent()

	emit("SYSTEM", "SNAPSHOT_END", {
		ts = os.time(),
	})

	debugLog("SNAPSHOT_FUNCTION_EXIT", {
		ts = os.time(),
	})
end

-- =========================
-- REALTIME SUBSCRIBE
-- =========================
if receiver and receiver.GlobalChanged then
	receiver.GlobalChanged:Connect(function(key, newValue, oldValue, path)
		if not path then
			debugLog("CHANGE_WITHOUT_PATH", {
				key = tostring(key),
			})
			return
		end

		if ignoredPaths[path] then
			return
		end

		debugLog("DATA_CHANGE", {
			ts = os.time(),
			key = tostring(key),
			path = tostring(path),
		})

		local data = safeGetData()
		if not data then return end

		if string.find(path, "SeedStocks/Shop/Stocks") then
			if data.SeedStocks and data.SeedStocks.Shop then
				emitBatch(
					"SEED",
					"Seed_Shop",
					data.SeedStocks.Shop.Stocks,
					data.SeedStocks.Shop.Seed
				)
			end
			return
		end

		if string.find(path, "SeedStocks/Daily Deals") then
			if data.SeedStocks and data.SeedStocks["Daily Deals"] then
				emitDailyDeals(data.SeedStocks["Daily Deals"])
			end
			return
		end

		if string.find(path, "GearStock/Stocks") then
			if data.GearStock then
				emitBatch(
					"GEAR",
					"Gear_Shop",
					data.GearStock.Stocks,
					data.GearStock.Gear
				)
			end
			return
		end

		if string.find(path, "PetEggStock") then
			if data.PetEggStock then
				emitPetEggStock(data.PetEggStock)
			end
			return
		end

		if string.find(path, "TravelingMerchantShopStock") then
			if data.TravelingMerchantShopStock then
				emitTravelingMerchantStock(data.TravelingMerchantShopStock)
			end
			return
		end

		if string.find(path, "EventShopStock/Easter Seed Shop/Stocks") then
			if data.EventShopStock and data.EventShopStock["Easter Seed Shop"] then
				emitBatch(
					"EVENT",
					"Easter Seed Shop",
					data.EventShopStock["Easter Seed Shop"].Stocks,
					data.EventShopStock["Easter Seed Shop"].ShopSeed
				)
			end
			return
		end
	end)

	debugLog("DATA_SUBSCRIPTION_ACTIVE")
else
	debugLog("RECEIVER_OR_GLOBAL_CHANGED_NOT_FOUND", {
		has_receiver = receiver ~= nil,
		has_global_changed = receiver and receiver.GlobalChanged ~= nil,
	})
end

