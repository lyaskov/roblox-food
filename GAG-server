local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DataService = require(ReplicatedStorage.Modules.DataService)

-- Paths to ignore
local ignoredPaths = {
    ["SaveSlots/AllSlots/DEFAULT/LastSaveTime"] = true,
    ["SaveSlots/AllSlots/DEFAULT/LastPetEggsIncubationTime"] = true,
    ["SaveSlots/AllSlots/DEFAULT/LastObjectsSaveTime"] = true,
    ["LastPetsSaveTime"] = true,
    ["LastSaveTime"] = true,
    ["LastPetsIncubationTime"] = true,
}

-- Paths to check for equality
local equalityCheckPaths = {
    ["TravelingMerchantShopStock/Stocks"] = true,
}

-- Function to convert table to readable string
local function tableToString(tbl, indent)
    indent = indent or 0
    local spacing = string.rep("    ", indent)
    
    if type(tbl) ~= "table" then
        return tostring(tbl)
    end
    
    local result = "{\n"
    for key, value in pairs(tbl) do
        local keyStr = type(key) == "string" and ('"' .. key .. '"') or tostring(key)
        if type(value) == "table" then
            result = result .. spacing .. "    [" .. keyStr .. "] = " .. tableToString(value, indent + 1) .. ",\n"
        else
            result = result .. spacing .. "    [" .. keyStr .. "] = " .. tostring(value) .. ",\n"
        end
    end
    result = result .. spacing .. "}"
    return result
end

-- Function to check if two values are equal
local function isEqual(a, b)
    if type(a) ~= type(b) then return false end
    if type(a) ~= "table" then return a == b end
    
    local checked = {}
    for k, v in pairs(a) do
        if not isEqual(v, b[k]) then return false end
        checked[k] = true
    end
    for k in pairs(b) do
        if not checked[k] then return false end
    end
    return true
end

-- Subscribe to data changes
local receiver = DataService.Receiver
if receiver and receiver.GlobalChanged then
    receiver.GlobalChanged:Connect(function(key, newValue, oldValue, path)
        -- Skip ignored paths
        if path and ignoredPaths[path] then
            return
        end
        
        -- Skip if values are equal (only for specific paths)
        if path and equalityCheckPaths[path] and isEqual(oldValue, newValue) then
            return
        end
        
        print("\n=== DATA CHANGED ===")
        print("Path:", path)
        print("Key:", key)
        print("\nOld value:")
        if type(oldValue) == "table" then
            print(tableToString(oldValue))
        else
            print(tostring(oldValue))
        end
        print("\nNew value:")
        if type(newValue) == "table" then
            print(tableToString(newValue))
        else
            print(tostring(newValue))
        end
        print("====================\n")
    end)
    print("Data subscription active!")
end

