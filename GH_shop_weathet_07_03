--[[

Robust SeedShop / GearShop GUI tracker + Weather (robust END)

MACHINE-PARSABLE ONLY:
  warn("SHOP|<KIND>|<JSON>")
  warn("WEATHER|<KIND>|<JSON>")

SHOP chunk:
  SHOP|BATCH_START|{...}
  SHOP|ITEM|{...} ...
  SHOP|BATCH_END|{...}

WEATHER chunk (so you can write to DB immediately on START):
  WEATHER|BATCH_START|{"weather_id":N,"ts":...,"name":"Snow","source":"...","detail":"..."}
  WEATHER|BATCH_END|{"weather_id":N,"ts":...,"name":"Snow","reason":"...","next":"Rain"?}

Robust weather END guarantees via:
  1) RemoteEvent (WeatherStarted/SyncWeather/WeatherEnded/ClearWeather)
  2) Attribute страховка (CurrentWeather changed)
  3) Duration watchdog (from WeatherDataDefinitions.Duration)
  4) Poll страховка (periodic read CurrentWeather)

]]--

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RS = game:GetService("ReplicatedStorage")

local lp = Players.LocalPlayer
local pg = lp:WaitForChild("PlayerGui")

-- =======================
-- SETTINGS
-- =======================
local DEBOUNCE_SECONDS = 0.40
local TIMER_INTERVAL = 1.0

-- WEATHER safety settings
local WEATHER_POLL_INTERVAL = 1.0
local WEATHER_END_GRACE_SECONDS = 2.0

-- =======================
-- EMIT (SHOP)
-- =======================
local function emit(kind, payload)
	warn("SHOP|" .. kind .. "|" .. HttpService:JSONEncode(payload))
end

-- =======================
-- EMIT (WEATHER)
-- =======================
local function emitWeather(kind, payload)
	warn("WEATHER|" .. kind .. "|" .. HttpService:JSONEncode(payload))
end

-- ============================================================
-- WEATHER (BATCH-LIKE: BATCH_START / BATCH_END) + robust END
-- ============================================================

-- Weather definitions (for Duration watchdog)
local WeatherDefs = nil
do
	local wFolder = RS:FindFirstChild("Weather")
	if wFolder then
		local defsModule = wFolder:FindFirstChild("WeatherDataDefinitions")
		if defsModule and defsModule:IsA("ModuleScript") then
			local ok, defs = pcall(require, defsModule)
			if ok and type(defs) == "table" then
				WeatherDefs = defs
			else
				emitWeather("INFO", { ts = os.time(), msg = "WeatherDataDefinitions require failed" })
			end
		else
			emitWeather("INFO", { ts = os.time(), msg = "WeatherDataDefinitions ModuleScript not found" })
		end
	else
		emitWeather("INFO", { ts = os.time(), msg = "ReplicatedStorage.Weather folder not found" })
	end
end

-- RemoteEvent
local weatherEvent = nil
do
	local ok, result = pcall(function()
		local re = RS:WaitForChild("RemoteEvents", 10)
		if not re then
			return nil
		end
		return re:WaitForChild("WeatherEvent", 10)
	end)

	if ok then
		weatherEvent = result
	else
		weatherEvent = nil
	end
end

-- State
local lastWeather = nil
local weatherSeq = 0
local activeWeatherId = nil

-- Watchdog cancel token (invalidate on switch/end)
local watchdogToken = 0

local function normalizeWeatherName(name)
	if not name then
		return nil
	end
	name = tostring(name)
	if name == "" or name == "Normal" then
		return nil
	end
	return name
end

local function extractWeatherName(payload)
	if payload == nil then
		return nil
	end

	if type(payload) == "string" then
		return payload
	end

	if type(payload) == "table" then
		if payload.Name ~= nil then
			return payload.Name
		end
		if payload.name ~= nil then
			return payload.name
		end
	end

	local ok, value = pcall(function()
		return payload.Name
	end)
	if ok and value ~= nil then
		return value
	end

	return nil
end

local function getWeatherDurationSeconds(weatherKeyOrName)
	if not WeatherDefs then
		return nil
	end

	local key = tostring(weatherKeyOrName or "")
	local def = WeatherDefs[key]
	if def and type(def) == "table" then
		local d = tonumber(def.Duration)
		if d and d > 0 then
			return d
		end
	end

	-- fallback: match by displayed Name field
	for _, v in pairs(WeatherDefs) do
		if type(v) == "table" and tostring(v.Name) == key then
			local d = tonumber(v.Duration)
			if d and d > 0 then
				return d
			end
		end
	end

	return nil
end

local function weatherEnd(reason, nextName)
	if not activeWeatherId then
		lastWeather = nil
		return
	end

	local payload = {
		weather_id = activeWeatherId,
		ts = os.time(),
		name = tostring(lastWeather or ""),
		reason = tostring(reason or "ended"),
	}
	if nextName then
		payload.next = tostring(nextName)
	end

	emitWeather("BATCH_END", payload)

	activeWeatherId = nil
	lastWeather = nil
	watchdogToken += 1 -- cancel any pending watchdog
end

local function weatherStart(name, source, detail)
	weatherSeq += 1
	activeWeatherId = weatherSeq
	local ts = os.time()

	emitWeather("BATCH_START", {
		weather_id = activeWeatherId,
		ts = ts,
		name = tostring(name),
		source = tostring(source or "unknown"),
		detail = tostring(detail or ""),
	})

	-- Duration watchdog (guarantee END even if no events)
	local dur = getWeatherDurationSeconds(name)
	if dur and dur > 0 then
		watchdogToken += 1
		local myToken = watchdogToken
		local myId = activeWeatherId
		local myName = tostring(name)

		task.delay(dur + WEATHER_END_GRACE_SECONDS, function()
			if myToken ~= watchdogToken then
				return
			end
			if activeWeatherId ~= myId then
				return
			end
			if lastWeather ~= myName then
				return
			end

			-- force end
			weatherEnd("duration_timeout")
		end)
	else
		-- still OK: attribute/event/poll will end it
		emitWeather("INFO", {
			ts = os.time(),
			msg = "No duration for weather; duration watchdog disabled",
			name = tostring(name),
		})
	end
end

local function applyWeatherState(newName, source, detail)
	emitWeather("INFO", {
		ts = os.time(),
		msg = "applyWeatherState called",
		raw_name = newName and tostring(newName) or nil,
		source = tostring(source or ""),
		detail = tostring(detail or ""),
		lastWeather = lastWeather and tostring(lastWeather) or nil,
		activeWeatherId = activeWeatherId,
	})

	newName = normalizeWeatherName(newName)

	-- Ended (Normal/empty)
	if not newName then
		if lastWeather then
			weatherEnd(detail or "ended")
		end
		return
	end

	-- Dedup
	if lastWeather == newName then
		return
	end

	-- Switch old -> new
	if lastWeather and lastWeather ~= newName then
		weatherEnd("switch", newName)
	end

	lastWeather = newName
	weatherStart(newName, source, detail)
end

local function startWeatherLogging()
	-- initial snapshot
	applyWeatherState(workspace:GetAttribute("CurrentWeather"), "startup_attr", "CurrentWeather")

	-- RemoteEvent
	if weatherEvent then
		weatherEvent.OnClientEvent:Connect(function(action, payload)
			local nameFromPayload = extractWeatherName(payload)

			emitWeather("INFO", {
				ts = os.time(),
				msg = "WeatherEvent received",
				action = tostring(action),
				payload_type = typeof(payload),
				payload_name = nameFromPayload and tostring(nameFromPayload) or nil,
				current_attr = workspace:GetAttribute("CurrentWeather"),
			})

			if action == "WeatherStarted" then
				applyWeatherState(
					nameFromPayload or workspace:GetAttribute("CurrentWeather"),
					"remote",
					"WeatherStarted"
				)

			elseif action == "SyncWeather" then
				applyWeatherState(
					nameFromPayload or workspace:GetAttribute("CurrentWeather"),
					"remote",
					"SyncWeather"
				)

			elseif action == "WeatherEnded" or action == "ClearWeather" then
				applyWeatherState(nil, "remote", tostring(action))

			elseif action == "VisualEffect" then
				emitWeather("INFO", {
					ts = os.time(),
					msg = "VisualEffect ignored for weather state",
				})

			else
				applyWeatherState(
					workspace:GetAttribute("CurrentWeather"),
					"remote_unknown",
					tostring(action)
				)
			end
		end)

		emitWeather("INFO", { ts = os.time(), msg = "WeatherEvent hook attached" })
	else
		emitWeather("INFO", { ts = os.time(), msg = "WeatherEvent not found; events disabled" })
	end

	-- Attribute страховка
	workspace:GetAttributeChangedSignal("CurrentWeather"):Connect(function()
		applyWeatherState(workspace:GetAttribute("CurrentWeather"), "attr", "CurrentWeather changed")
	end)
	emitWeather("INFO", { ts = os.time(), msg = "Weather attribute hook attached" })

	-- Poll страховка
	task.spawn(function()
		while true do
			task.wait(WEATHER_POLL_INTERVAL)
			applyWeatherState(workspace:GetAttribute("CurrentWeather"), "poll", "poll_tick")
		end
	end)
	emitWeather("INFO", {
		ts = os.time(),
		msg = "Weather poll watchdog started",
		interval = WEATHER_POLL_INTERVAL,
	})
end

-- ============================================================
-- FORCE GUI ENABLED
-- ============================================================
local function keepGuiEnabled(guiName)
	local gui = pg:WaitForChild(guiName)

	if gui:IsA("ScreenGui") then
		gui.Enabled = true
		gui:GetPropertyChangedSignal("Enabled"):Connect(function()
			if gui.Enabled == false then
				gui.Enabled = true
				emit("INFO", { ts = os.time(), shop = guiName, msg = guiName .. ".Enabled forced true" })
			end
		end)
		emit("INFO", { ts = os.time(), shop = guiName, msg = guiName .. " enabled watcher attached" })
	else
		emit("INFO", {
			ts = os.time(),
			shop = guiName,
			msg = guiName .. " is not ScreenGui (skip Enabled lock)",
		})
	end

	return gui
end

-- =======================
-- VISIBILITY (parent chain)
-- =======================
local function isActuallyVisible(guiObj)
	if not guiObj or not guiObj:IsA("GuiObject") then
		return false
	end
	if not guiObj.Visible then
		return false
	end

	local p = guiObj.Parent
	while p do
		if p:IsA("GuiObject") and not p.Visible then
			return false
		end
		p = p.Parent
	end
	return true
end

-- =======================
-- FILTER TEMPLATE / HIDDEN
-- =======================
local function isRealItem(guiObj)
	if not guiObj or not guiObj:IsA("GuiObject") then
		return false
	end
	if not isActuallyVisible(guiObj) then
		return false
	end

	local n = string.lower(guiObj.Name)
	if n == "itemtemplate" then
		return false
	end
	if string.find(n, "template", 1, true) then
		return false
	end

	return true
end

-- =======================
-- GET LABELS (SEED / GEAR)
-- =======================
local function getItemLabels(shopType, itemFrame)
	local mainInfo = itemFrame:FindFirstChild("MainInfo")
	if not mainInfo then
		return nil, nil
	end

	local stockLabel = mainInfo:FindFirstChild("StockText")
	local nameLabel

	if shopType == "SeedShop" then
		nameLabel = mainInfo:FindFirstChild("SeedNameShadow")
	else
		nameLabel = mainInfo:FindFirstChild("GearNameShadow")
	end

	if not nameLabel or not stockLabel then
		return nil, nil
	end
	return nameLabel, stockLabel
end

-- =======================
-- TRACKER CORE
-- =======================
local dumpScheduled = { SeedShop = false, GearShop = false }
local batchSeq = 0

local hookedItemFrames = setmetatable({}, { __mode = "k" })
local hookedScrollFrames = setmetatable({}, { __mode = "k" })

local function dumpAll(shopType, scrollingFrame, reason)
	batchSeq += 1
	local batchId = batchSeq
	local ts = os.time()

	emit("BATCH_START", {
		shop = shopType,
		batch_id = batchId,
		ts = ts,
		reason = tostring(reason),
	})

	local count = 0
	for _, item in ipairs(scrollingFrame:GetChildren()) do
		if isRealItem(item) then
			local nameLabel, stockLabel = getItemLabels(shopType, item)
			if nameLabel and stockLabel then
				count += 1
				emit("ITEM", {
					shop = shopType,
					batch_id = batchId,
					ts = ts,
					name = tostring(nameLabel.Text),
					stock = tostring(stockLabel.Text),
					ui_name = item.Name,
					layout = item.LayoutOrder or 0,
				})
			end
		end
	end

	emit("BATCH_END", {
		shop = shopType,
		batch_id = batchId,
		ts = ts,
		items = count,
	})
end

local function scheduleDump(shopType, scrollingFrame, reason)
	if dumpScheduled[shopType] then
		return
	end
	dumpScheduled[shopType] = true

	task.delay(DEBOUNCE_SECONDS, function()
		dumpScheduled[shopType] = false
		if scrollingFrame and scrollingFrame.Parent then
			dumpAll(shopType, scrollingFrame, reason)
		else
			emit("INFO", {
				ts = os.time(),
				shop = shopType,
				msg = "Dump skipped: ScrollingFrame destroyed",
				reason = tostring(reason),
			})
		end
	end)
end

local function hookItem(shopType, itemFrame, scrollingFrame)
	if not isRealItem(itemFrame) then
		return
	end
	if hookedItemFrames[itemFrame] then
		return
	end
	hookedItemFrames[itemFrame] = true

	local function tryWireLabels(reason)
		if not itemFrame or not itemFrame.Parent then
			return
		end
		if not isRealItem(itemFrame) then
			return
		end

		local nameLabel, stockLabel = getItemLabels(shopType, itemFrame)
		if not nameLabel or not stockLabel then
			return
		end

		if not itemFrame:GetAttribute("_shop_wired") then
			itemFrame:SetAttribute("_shop_wired", true)

			stockLabel:GetPropertyChangedSignal("Text"):Connect(function()
				scheduleDump(shopType, scrollingFrame, "StockText changed")
			end)

			nameLabel:GetPropertyChangedSignal("Text"):Connect(function()
				scheduleDump(shopType, scrollingFrame, "Name changed")
			end)

			itemFrame:GetPropertyChangedSignal("Visible"):Connect(function()
				scheduleDump(shopType, scrollingFrame, "Item visibility changed")
			end)

			emit("INFO", {
				ts = os.time(),
				shop = shopType,
				msg = "Item wired",
				ui_name = itemFrame.Name,
			})

			scheduleDump(shopType, scrollingFrame, reason or "Item wired")
		end
	end

	tryWireLabels("hookItem initial")

	itemFrame.DescendantAdded:Connect(function(_d)
		task.wait(0.03)
		tryWireLabels("DescendantAdded")
	end)
end

local function hookScrollingFrame(shopType, scrollingFrame)
	if not scrollingFrame or not scrollingFrame.Parent then
		return
	end
	if hookedScrollFrames[scrollingFrame] then
		return
	end
	hookedScrollFrames[scrollingFrame] = true

	for _, item in ipairs(scrollingFrame:GetChildren()) do
		hookItem(shopType, item, scrollingFrame)
	end

	scrollingFrame.ChildAdded:Connect(function(item)
		task.wait(0.05)
		hookItem(shopType, item, scrollingFrame)
	end)

	scrollingFrame.ChildRemoved:Connect(function(_item)
		scheduleDump(shopType, scrollingFrame, "ChildRemoved")
	end)

	emit("INFO", {
		ts = os.time(),
		shop = shopType,
		msg = "hookScrollingFrame attached",
		path = scrollingFrame:GetFullName(),
	})
end

local function hookShop(shopType, gui)
	local frame = gui:WaitForChild("Frame", 10)
	if not frame then
		emit("ERROR", { ts = os.time(), shop = shopType, msg = "Frame not found" })
		return
	end

	local scrollingFrame = frame:WaitForChild("ScrollingFrame", 10)
	if not scrollingFrame then
		emit("ERROR", { ts = os.time(), shop = shopType, msg = "ScrollingFrame not found" })
		return
	end

	hookScrollingFrame(shopType, scrollingFrame)

	gui.DescendantAdded:Connect(function(d)
		if d:IsA("ScrollingFrame") and d.Name == "ScrollingFrame" then
			task.wait(0.05)
			emit("INFO", {
				ts = os.time(),
				shop = shopType,
				msg = "New ScrollingFrame detected",
				path = d:GetFullName(),
			})
			hookScrollingFrame(shopType, d)
			scheduleDump(shopType, d, "New ScrollingFrame detected")
		end
	end)

	scheduleDump(shopType, scrollingFrame, "startup")
end

-- =======================
-- SEED TIMER HEARTBEAT
-- =======================
local function startSeedTimer(seedShopGui)
	local timerLabel = seedShopGui
		:WaitForChild("Frame")
		:WaitForChild("TopBar")
		:WaitForChild("Timer")

	task.spawn(function()
		local last = nil
		while true do
			task.wait(TIMER_INTERVAL)
			if not timerLabel or not timerLabel.Parent then
				emit("INFO", {
					ts = os.time(),
					shop = "SeedShop",
					msg = "Timer label destroyed, timer loop stopped",
				})
				break
			end

			local v = tostring(timerLabel.Text)
			if v ~= last then
				last = v
				emit("TIMER", { shop = "SeedShop", ts = os.time(), value = v })
			end
		end
	end)

	emit("INFO", { ts = os.time(), shop = "SeedShop", msg = "Timer heartbeat started" })
end

-- =======================
-- START
-- =======================
local seedGui = keepGuiEnabled("SeedShop")
local gearGui = keepGuiEnabled("GearShop")

hookShop("SeedShop", seedGui)
hookShop("GearShop", gearGui)

startSeedTimer(seedGui)
startWeatherLogging()

-- If GUIs appear later
pg.ChildAdded:Connect(function(child)
	if child.Name == "SeedShop" then
		local g = keepGuiEnabled("SeedShop")
		hookShop("SeedShop", g)
		startSeedTimer(g)
	elseif child.Name == "GearShop" then
		local g = keepGuiEnabled("GearShop")
		hookShop("GearShop", g)
	end
end)
