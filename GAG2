local RS = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local StockValues = RS:WaitForChild("StockValues")
local pending = false

local function readValue(obj)
    if obj:IsA("NumberValue")
    or obj:IsA("IntValue")
    or obj:IsA("StringValue")
    or obj:IsA("BoolValue") then
        return obj.Value
    end
    return nil
end

local function snapshot()
    local result = {}

    for _, shopFolder in ipairs(StockValues:GetChildren()) do
        local shopName = shopFolder.Name

        result[shopName] = {
            Items = {},
            UnixLastRestock = nil,
            UnixNextRestock = nil,
        }

        local items = shopFolder:FindFirstChild("Items")
        if items then
            for _, item in ipairs(items:GetChildren()) do
                local value = readValue(item)
                if value ~= nil then
                    result[shopName].Items[item.Name] = value
                end
            end
        end

        local last = shopFolder:FindFirstChild("UnixLastRestock")
        if last then
            result[shopName].UnixLastRestock = readValue(last)
        end

        local nextRestock = shopFolder:FindFirstChild("UnixNextRestock")
        if nextRestock then
            result[shopName].UnixNextRestock = readValue(nextRestock)
        end
    end

    warn("ALL_STOCK|" .. HttpService:JSONEncode(result))
end

local function delayedSnapshot()
    if pending then
        return
    end

    pending = true

    task.delay(1, function()
        pending = false
        snapshot()
    end)
end

local function hookValue(obj)
    if obj:IsA("NumberValue")
    or obj:IsA("IntValue")
    or obj:IsA("StringValue")
    or obj:IsA("BoolValue") then
        obj:GetPropertyChangedSignal("Value"):Connect(delayedSnapshot)
    end
end

local function hookItemsFolder(itemsFolder)
    for _, child in ipairs(itemsFolder:GetChildren()) do
        hookValue(child)
    end

    itemsFolder.ChildAdded:Connect(function(child)
        hookValue(child)
        delayedSnapshot()
    end)

    itemsFolder.ChildRemoved:Connect(delayedSnapshot)
end

for _, shopFolder in ipairs(StockValues:GetChildren()) do
    local items = shopFolder:FindFirstChild("Items")
    if items then
        hookItemsFolder(items)
    end

    local last = shopFolder:FindFirstChild("UnixLastRestock")
    if last then hookValue(last) end

    local nextRestock = shopFolder:FindFirstChild("UnixNextRestock")
    if nextRestock then hookValue(nextRestock) end
end

StockValues.ChildAdded:Connect(function(shopFolder)
    task.wait(0.5)

    local items = shopFolder:FindFirstChild("Items")
    if items then
        hookItemsFolder(items)
    end

    delayedSnapshot()
end)

snapshot()
warn("ALL_STOCK_LISTENER_READY")
