local RS = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

print("========================================")
print("GAG LIVE DATA TRACKER STARTED")
print("========================================")

local pendingStock = false
local pendingWeather = false

local function log(tag, data)
    local ok, json = pcall(function()
        return HttpService:JSONEncode(data)
    end)

    if ok then
        warn(tag .. "|" .. json)
    else
        warn(tag .. "|" .. tostring(data))
    end
end

local function readValue(obj)
    if obj and obj:IsA("ValueBase") then
        return obj.Value
    end
    return nil
end

-- =========================
-- STOCK
-- =========================

local function snapshotStock()
    local StockValues = RS:FindFirstChild("StockValues")
    if not StockValues then
        warn("STOCK|NOT_FOUND")
        return
    end

    local result = {}

    for _, shop in ipairs(StockValues:GetChildren()) do
        result[shop.Name] = {
            Items = {},
            UnixLastRestock = readValue(shop:FindFirstChild("UnixLastRestock")),
            UnixNextRestock = readValue(shop:FindFirstChild("UnixNextRestock")),
        }

        local items = shop:FindFirstChild("Items")
        if items then
            for _, item in ipairs(items:GetChildren()) do
                if item:IsA("ValueBase") then
                    result[shop.Name].Items[item.Name] = item.Value
                end
            end
        end
    end

    log("STOCK", result)
end

local function delayedStock()
    if pendingStock then return end
    pendingStock = true

    task.delay(1, function()
        pendingStock = false
        snapshotStock()
    end)
end

local function hookStock()
    local StockValues = RS:FindFirstChild("StockValues")
    if not StockValues then
        warn("STOCK_HOOK|NOT_FOUND")
        return
    end

    for _, obj in ipairs(StockValues:GetDescendants()) do
        if obj:IsA("ValueBase") then
            obj:GetPropertyChangedSignal("Value"):Connect(delayedStock)
        end
    end

    StockValues.DescendantAdded:Connect(function(obj)
        if obj:IsA("ValueBase") then
            obj:GetPropertyChangedSignal("Value"):Connect(delayedStock)
            delayedStock()
        end
    end)

    warn("STOCK_HOOK|READY")
    snapshotStock()
end

