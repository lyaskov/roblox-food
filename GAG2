local INTEREST_WORDS = {
    "Shop",
    "Stock",
    "Restock",
    "Weather",
    "Rain",
    "Lightning",
    "Rainbow",
    "Bloodmoon",
    "Night",
    "Pet",
    "Egg",
    "Event",
    "Reward",
    "Gift",
    "Quest",
    "Mail",
    "Notification",
}

local unknownCounts = {}

local function hasInterestWord(path)
    local lower = string.lower(path)

    for _, word in ipairs(INTEREST_WORDS) do
        if string.find(lower, string.lower(word), 1, true) then
            return true
        end
    end

    return false
end

local function json(value)
    local ok, result = pcall(function()
        return HttpService:JSONEncode(value)
    end)

    return ok and result or tostring(value)
end

local function compact(value, depth)
    depth = depth or 0

    if depth > 3 then
        return "..."
    end

    local t = typeof(value)

    if value == nil then
        return "nil"
    elseif t == "string" then
        return '"' .. value .. '"'
    elseif t == "number" or t == "boolean" then
        return tostring(value)
    elseif t == "Vector3" then
        return string.format("Vector3(%.1f, %.1f, %.1f)", value.X, value.Y, value.Z)
    elseif t == "CFrame" then
        local p = value.Position
        return string.format("CFrame(%.1f, %.1f, %.1f)", p.X, p.Y, p.Z)
    elseif t == "Instance" then
        return "Instance[" .. value.ClassName .. " " .. value:GetFullName() .. "]"
    elseif type(value) == "table" then
        local parts = {}
        local count = 0

        for k, v in pairs(value) do
            count += 1
            table.insert(parts, tostring(k) .. "=" .. compact(v, depth + 1))

            if count >= 10 then
                table.insert(parts, "...")
                break
            end
        end

        return "{" .. table.concat(parts, ", ") .. "}"
    end

    return tostring(value)
end

local function printAllowed(path, args)
    -- Полный вывод важных таблиц
    if path == "ExclusiveShop.DealUpdate" then
        warn("ALLOW_FULL|" .. path .. "|" .. json(args[1]))
        return
    end

    local out = {}

    for i, v in ipairs(args) do
        out[i] = compact(v)
    end

    warn("ALLOW|" .. path .. "|" .. table.concat(out, ", "))
end

local function printUnknown(path, args)
    unknownCounts[path] = (unknownCounts[path] or 0) + 1

    local out = {}

    for i, v in ipairs(args) do
        out[i] = compact(v)
    end

    warn("NEW_UNKNOWN|" .. path .. "|COUNT=" .. unknownCounts[path] .. "|" .. table.concat(out, ", "))
    warn('HINT_IGNORE|["' .. path .. '"] = true,')
    warn('HINT_ALLOW|["' .. path .. '"] = true,')
end

local function shouldHook(path)
    if IGNORE_EXACT[path] then
        return false
    end

    if ALLOW_EXACT[path] then
        return true
    end

    if hasInterestWord(path) then
        return true
    end

    return false
end

local function handleEvent(path, ...)
    local args = { ... }

    if IGNORE_EXACT[path] then
        return
    end

    if ALLOW_EXACT[path] then
        printAllowed(path, args)
        return
    end

    printUnknown(path, args)
end

local function hookPacket(path, packet)
    if type(packet) ~= "table" then
        return
    end

    if packet.OnClientEvent and typeof(packet.OnClientEvent.Connect) == "function" then
        if shouldHook(path) then
            local ok, err = pcall(function()
                packet.OnClientEvent:Connect(function(...)
                    handleEvent(path, ...)
                end)
            end)

            if ok then
                print("HOOK|" .. path)
            else
                warn("HOOK_FAILED|" .. path .. "|" .. tostring(err))
            end
        end

        return
    end

    for key, value in pairs(packet) do
        if type(key) == "string" and type(value) == "table" then
            local subPath = path == "" and key or (path .. "." .. key)
            hookPacket(subPath, value)
        end
    end
end

