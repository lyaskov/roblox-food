local Net = require(game.ReplicatedStorage.SharedModules.Networking)
local HttpService = game:GetService("HttpService")

local function json(v)
    local ok, result = pcall(function()
        return HttpService:JSONEncode(v)
    end)

    if ok then
        return result
    end

    return tostring(v)
end

local function log(tag, ...)
    warn("GAG|" .. tag .. "|" .. json({ ... }))
end

-- Seed restock
if Net.SeedShop and Net.SeedShop.PersonalRestock then
    Net.SeedShop.PersonalRestock.OnClientEvent:Connect(function(...)
        log("SEED_PERSONAL_RESTOCK", ...)
    end)

    warn("GAG|LISTENING|SEED_PERSONAL_RESTOCK")
else
    warn("GAG|NOT_FOUND|SEED_PERSONAL_RESTOCK")
end

