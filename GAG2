local RS = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local StockValues = RS:WaitForChild("StockValues")

local function snapshot()
    local result = {}

    for _, shopFolder in ipairs(StockValues:GetChildren()) do
        local shopName = shopFolder.Name
        result[shopName] = {
            Items = {},
            UnixLastRestock = nil,
            UnixNextRestock = nil
        }

        local items = shopFolder:FindFirstChild("Items")
        if items then
            for _, v in ipairs(items:GetChildren()) do
                if v:IsA("NumberValue") or v:IsA("IntValue") then
                    result[shopName].Items[v.Name] = v.Value
                end
            end
        end

        local last = shopFolder:FindFirstChild("UnixLastRestock")
        if last then
            result[shopName].UnixLastRestock = last.Value
        end

        local next = shopFolder:FindFirstChild("UnixNextRestock")
        if next then
            result[shopName].UnixNextRestock = next.Value
        end
    end

    warn("ALL_STOCK|" .. HttpService:JSONEncode(result))
end

snapshot()

for _, shopFolder in ipairs(StockValues:GetChildren()) do
    local items = shopFolder:FindFirstChild("Items")
    if items then
        for _, v in ipairs(items:GetChildren()) do
            if v:IsA("NumberValue") or v:IsA("IntValue") then
                v:GetPropertyChangedSignal("Value"):Connect(snapshot)
            end
        end
    end
end

warn("ALL_STOCK_LISTENER_READY")
