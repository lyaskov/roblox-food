local function loadWeatherDefinitions()
    local weatherValues = RS:FindFirstChild("WeatherValues")
    local sharedModules = RS:FindFirstChild("SharedModules")
    local weatherModule = sharedModules and sharedModules:FindFirstChild("WeatherData")
    if not weatherValues or not weatherModule then
        emit("SYSTEM", "WEATHER_STATE_UNAVAILABLE", {
            ts = now(),
            weather_values = weatherValues ~= nil,
            weather_data = weatherModule ~= nil,
        })
        return nil, {}
    end

    local ok, weatherData = pcall(function()
        return require(weatherModule)
    end)
    if not ok or type(weatherData) ~= "table" or type(weatherData.Data) ~= "table" then
        emit("SYSTEM", "WEATHER_DATA_REQUIRE_FAILED", {
            ts = now(),
        })
        return weatherValues, {}
    end

    local definitions = {}
    for _, entry in ipairs(weatherData.Data) do
        if type(entry) == "table" and entry.Name ~= nil then
            local name = tostring(entry.Name)
            definitions[name] = {
                name = name,
                duration = tonumber(entry.Last) or 0,
            }
        end
    end

    return weatherValues, definitions
end

local function emitWeatherState(kind, payload)
    emit("WEATHER", kind, payload)
end

local function buildWeatherStatePayload(name, definition, weatherValues, playing)
    local endTime = tonumber(weatherValues:GetAttribute(name .. "_EndTime")) or 0
    local ts = now()
    return {
        ts = ts,
        path = "WeatherValues." .. name,
        source = "WeatherValues",
        name = name,
        argc = 0,
        args = {},
        playing = playing == true,
        duration = definition.duration or 0,
        end_time = endTime,
        remaining = math.max(0, endTime - ts),
    }
end

local function hookWeatherStates()
    local weatherValues, definitions = loadWeatherDefinitions()
    if not weatherValues then
        return
    end

    local count = 0

    for name, definition in pairs(definitions) do
        count += 1
        local attributeName = name .. "_Playing"
        local currentPlaying = weatherValues:GetAttribute(attributeName)
        if currentPlaying == true then
            emitWeatherState(name .. "StateActive", buildWeatherStatePayload(name, definition, weatherValues, true))
        end

        weatherValues:GetAttributeChangedSignal(attributeName):Connect(function()
            local playing = weatherValues:GetAttribute(attributeName) == true
            local suffix = playing and "StateStart" or "StateEnd"
            emitWeatherState(name .. suffix, buildWeatherStatePayload(name, definition, weatherValues, playing))
        end)
    end

    emit("SYSTEM", "WEATHER_STATE_HOOK_READY", {
        ts = now(),
        weather_count = count,
    })
end

local function buildWorkspaceWeatherPayload(weatherName, playing)
    return {
        ts = now(),
        path = "Workspace.ActiveWeather",
        source = "Workspace",
        name = tostring(weatherName or ""),
        argc = 0,
        args = {},
        playing = playing == true,
    }
end

local function hookWorkspaceWeather()
    local lastWeather = workspace:GetAttribute("ActiveWeather")

    if type(lastWeather) == "string" and lastWeather ~= "" then
        emit("WEATHER", lastWeather .. "StateActive", buildWorkspaceWeatherPayload(lastWeather, true))
    end

    workspace:GetAttributeChangedSignal("ActiveWeather"):Connect(function()
        local nextWeather = workspace:GetAttribute("ActiveWeather")

        if type(lastWeather) == "string" and lastWeather ~= "" and lastWeather ~= nextWeather then
            emit("WEATHER", lastWeather .. "StateEnd", buildWorkspaceWeatherPayload(lastWeather, false))
        end

        if type(nextWeather) == "string" and nextWeather ~= "" and nextWeather ~= lastWeather then
            emit("WEATHER", nextWeather .. "StateStart", buildWorkspaceWeatherPayload(nextWeather, true))
        end

        lastWeather = nextWeather
    end)

    emit("SYSTEM", "WORKSPACE_WEATHER_HOOK_READY", {
        ts = now(),
        active_weather = tostring(lastWeather or ""),
    })
end

