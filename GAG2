emit("SYSTEM", "SCRIPT_START", {
    ts = now(),
})

hookStockValues()
hookWildPets()
hookNetworking()

emit("SYSTEM", "SCRIPT_READY", {
    ts = now(),
    hooked_network_events = hookedCount,
})
