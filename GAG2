local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")

local function toJson(value)
    local ok, json = pcall(function()
        return HttpService:JSONEncode(value)
    end)

    if ok then
        return json
    end

    return tostring(value)
end

local function hasKeyword(text)
    text = string.lower(text)

    local keywords = {
        "stock",
        "shop",
        "seed",
        "gear",
        "pet",
        "egg",
        "crate",
        "restock",
        "purchasedthisrestock",
    }

    for _, word in ipairs(keywords) do
        if string.find(text, word) then
            return true
        end
    end

    return false
end

local function emit(eventName, args)
    local json = toJson(args)

    if hasKeyword(json) then
        warn("GAG|" .. eventName .. "|" .. json)
    end
end

local function listen(remoteName)
    local remote = RemoteEvents:FindFirstChild(remoteName)

    if not remote then
        warn("NOT_FOUND|" .. remoteName)
        return
    end

    remote.OnClientEvent:Connect(function(...)
        local args = { ... }
        emit(remoteName, args)
    end)

    warn("LISTENING|" .. remoteName)
end

listen("ReplicaCreate")
listen("ReplicaSet")
listen("ReplicaSetValues")
listen("ReplicaTableInsert")
listen("ReplicaTableRemove")
listen("ReplicaWrite")
listen("ReplicaSignal")
listen("ReplicaBind")

warn("GAG|SCRIPT_READY")
