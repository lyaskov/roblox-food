-- PRICE FINDER
-- =========================================================

local PRICE_KEYS = {
    "Price",
    "price",
    "Cost",
    "cost",
    "Coins",
    "coins",
    "Value",
    "value",
    "priceInRobux",
    "PriceInRobux",
    "PurchasePrice",
}

local priceModules = {}
local directPriceIndexes = {
    SeedShop = {},
    GearShop = {},
}
local directPriceResolvers = {}

local function normalizeName(value)
    if value == nil then
        return nil
    end

    local normalized = string.lower(tostring(value))
    normalized = string.gsub(normalized, "[%s%p_]+", "")

    if normalized == "" then
        return nil
    end

    return normalized
end

local function getTablePrice(entry, source)
    if type(entry) == "table" then
        for _, key in ipairs(PRICE_KEYS) do
            if entry[key] ~= nil then
                return entry[key], source
            end
        end
    elseif type(entry) == "number" then
        return entry, source .. "_number"
    end

    return nil
end

local function findPriceInTable(data, itemNames, depth)
    depth = depth or 0

    if depth > 7 or type(data) ~= "table" then
        return nil
    end

    local normalizedNames = {}

    for _, itemName in ipairs(itemNames) do
        local direct = data[itemName]
        local directPrice, directSource = getTablePrice(direct, "module_direct")
        if directPrice ~= nil then
            return directPrice, directSource
        end

        local normalized = normalizeName(itemName)
        if normalized then
            normalizedNames[normalized] = true
        end
    end

    for k, v in pairs(data) do
        if type(v) == "table" then
            local candidateNames = {
                tostring(k),
                v.Name,
                v.ItemName,
                v.itemName,
                v.DisplayName,
                v.SeedName,
                v.GearName,
                v.CrateName,
            }
            local matchesName = false

            for _, candidateName in ipairs(candidateNames) do
                if candidateName ~= nil then
                    for _, itemName in ipairs(itemNames) do
                        if candidateName == itemName then
                            matchesName = true
                            break
                        end
                    end

                    if matchesName then
                        break
                    end

                    local normalizedCandidate = normalizeName(candidateName)
                    if normalizedCandidate and normalizedNames[normalizedCandidate] then
                        matchesName = true
                        break
                    end
                end
            end

            if matchesName then
                local nestedPrice, nestedSource = getTablePrice(v, "module_nested")
                if nestedPrice ~= nil then
                    return nestedPrice, nestedSource
                end
            end

            local price, source = findPriceInTable(v, itemNames, depth + 1)
            if price ~= nil then
                return price, source
            end
        end
    end

    return nil
end

local function tryLoadPriceModule(path)
    local current = RS

    for part in string.gmatch(path, "[^%.]+") do
        current = current:FindFirstChild(part)
        if not current then
            return
        end
    end

    local ok, data = pcall(function()
        return require(current)
    end)

    if ok and type(data) == "table" then
        table.insert(priceModules, {
            path = path,
            data = data,
        })

        emit("SYSTEM", "PRICE_MODULE_LOADED", {
            ts = now(),
            path = path,
        })
    else
        emit("SYSTEM", "PRICE_MODULE_FAILED", {
            ts = now(),
            path = path,
        })
    end
end

local function tryLoadDirectPriceIndex(path, targetTable, nameKey, priceKey)
    local current = RS

    for part in string.gmatch(path, "[^%.]+") do
        current = current:FindFirstChild(part)
        if not current then
            return
        end
    end

    local ok, data = pcall(function()
        return require(current)
    end)

    if not ok or type(data) ~= "table" then
        return
    end

    for _, entry in ipairs(data) do
        if type(entry) == "table" and entry[nameKey] ~= nil and entry[priceKey] ~= nil then
            targetTable[tostring(entry[nameKey])] = entry[priceKey]
        end
    end
end

local function tryLoadNestedDirectPriceIndex(path, rootKey, targetTable, nameKey, priceKey)
    local current = RS

    for part in string.gmatch(path, "[^%.]+") do
        current = current:FindFirstChild(part)
        if not current then
            return
        end
    end

    local ok, data = pcall(function()
        return require(current)
    end)

    if not ok or type(data) ~= "table" then
        return
    end

    local entries = data[rootKey]
    if type(entries) ~= "table" then
        return
    end

    for _, entry in ipairs(entries) do
        if type(entry) == "table" and entry[nameKey] ~= nil and entry[priceKey] ~= nil then
            targetTable[tostring(entry[nameKey])] = entry[priceKey]
        end
    end
end

local function tryLoadPriceResolver(path, builder)
    local current = RS

    for part in string.gmatch(path, "[^%.]+") do
        current = current:FindFirstChild(part)
        if not current then
            return nil
        end
    end

    local ok, data = pcall(function()
        return require(current)
    end)

    if not ok then
        return nil
    end

    return builder(data)
end

local function loadPriceModules()
    local paths = {
        "SharedModules.SeedData",
        "SharedModules.GearData",
        "SharedModules.CrateData",
        "SharedModules.PropData",
        "SharedModules.ShopData",
        "SharedModules.ItemData",
        "SharedModules.ItemsData",
        "SharedModules.CrateShopData",
        "SharedModules.GearShopData",
        "SharedModules.SeedShopData",
    }

    for _, path in ipairs(paths) do
        tryLoadPriceModule(path)
    end

    tryLoadDirectPriceIndex("SharedModules.SeedData", directPriceIndexes.SeedShop, "SeedName", "PurchasePrice")
    tryLoadNestedDirectPriceIndex("SharedModules.GearShopData", "Data", directPriceIndexes.GearShop, "ItemName", "Cost")

    local crateResolver = tryLoadPriceResolver("SharedModules.CrateData", function(crateData)
        if type(crateData) ~= "table" or type(crateData.GetData) ~= "function" then
            return nil
        end

        return function(itemNames)
            for _, itemName in ipairs(itemNames) do
                local ok, entry = pcall(crateData.GetData, itemName)
                if ok and type(entry) == "table" and entry.Cost ~= nil then
                    return entry.Cost, "CrateData.GetData"
                end
            end

            return nil
        end
    end)

    local guildCrateResolver = tryLoadPriceResolver("SharedModules.GuildCrateData", function(crateData)
        if type(crateData) ~= "table" or type(crateData.GetData) ~= "function" then
            return nil
        end

        return function(itemNames)
            for _, itemName in ipairs(itemNames) do
                local ok, entry = pcall(crateData.GetData, itemName)
                if ok and type(entry) == "table" then
                    local price = entry.Cost or entry.Price or entry.price or entry.PurchasePrice
                    if price ~= nil then
                        return price, "GuildCrateData.GetData"
                    end
                end
            end

            return nil
        end
    end)

    if crateResolver or guildCrateResolver then
        directPriceResolvers.CrateShop = function(itemNames)
            if crateResolver then
                local price, source = crateResolver(itemNames)
                if price ~= nil then
                    return price, source
                end
            end

            if guildCrateResolver then
                local price, source = guildCrateResolver(itemNames)
                if price ~= nil then
                    return price, source
                end
            end

            return nil
        end
    end
end

local function collectItemNames(item)
    local names = {}
    local seen = {}

    local function addName(value)
        if value == nil then
            return
        end

        local text = tostring(value)
        if text ~= "" and not seen[text] then
            seen[text] = true
            table.insert(names, text)
        end
    end

    addName(item.Name)
    addName(item:GetAttribute("Name"))
    addName(item:GetAttribute("ItemName"))
    addName(item:GetAttribute("itemName"))
    addName(item:GetAttribute("DisplayName"))

    for _, childName in ipairs({ "Name", "ItemName", "itemName", "DisplayName" }) do
        local child = item:FindFirstChild(childName)
        if child and child:IsA("ValueBase") then
            addName(child.Value)
        end
    end

    return names
end

local function getItemPrice(item, shopName)
    local itemNames = collectItemNames(item)

    if shopName and directPriceIndexes[shopName] then
        local priceIndex = directPriceIndexes[shopName]
        for _, itemName in ipairs(itemNames) do
            local directPrice = priceIndex[itemName]
            if directPrice ~= nil then
                return directPrice, shopName .. "_direct_index"
            end
        end
    end

    if shopName and directPriceResolvers[shopName] then
        local directPrice, directSource = directPriceResolvers[shopName](itemNames)
        if directPrice ~= nil then
            return directPrice, shopName .. "_resolver:" .. directSource
        end
    end

    -- 1. Атрибуты самого NumberValue
    for _, key in ipairs(PRICE_KEYS) do
        local attr = item:GetAttribute(key)
        if attr ~= nil then
            return attr, "attribute_" .. key
        end
    end

    -- 2. Дочерние ValueBase внутри item
    for _, key in ipairs(PRICE_KEYS) do
        local child = item:FindFirstChild(key)
        if child and child:IsA("ValueBase") then
            return child.Value, "child_" .. key
        end
    end

    -- 3. Модули SharedModules
    if #priceModules == 0 then
        return -1, "no_price_modules"
    end

    for _, mod in ipairs(priceModules) do
        local price, source = findPriceInTable(mod.data, itemNames)
        if price ~= nil then
            return price, mod.path .. ":" .. source
        end
    end

    emit("SYSTEM", "PRICE_NOT_FOUND", {
        ts = now(),
        item_name = item.Name,
        item_names = itemNames,
        price_modules_loaded = #priceModules,
    })

    return -1, "not_found"
end

-- =========================================================
-- STOCK WATCHER
-- =========================================================

local WATCH_SHOPS = {
    SeedShop = true,
    GearShop = true,
    CrateShop = true,
    ExclusiveShop = true,
}

local lastStock = {}
local stockSnapshotPending = false
local STOCK_REFRESH_INTERVAL = 300
local awaitingTimedRefresh = false
local awaitedRefreshMark = nil

local function getStockKey(shopName, itemName)
    return shopName .. "|" .. itemName
end

local function emitShopBatch(shop, reason)
    if not shop then return end

    local items = shop:FindFirstChild("Items")
    if not items then return end

    local cycleId = now()
    local count = 0

    emit("SHOP", "BATCH_START", {
        ts = now(),
        cycle_id = cycleId,
        source = "ReplicatedStorage.StockValues",
        reason = reason,
        shop = shop.Name,
        unix_last_restock = getValue(shop:FindFirstChild("UnixLastRestock")),
        unix_next_restock = getValue(shop:FindFirstChild("UnixNextRestock")),
    })

    for _, item in ipairs(items:GetChildren()) do
        if item:IsA("ValueBase") then
            count += 1

            local price, priceSource = getItemPrice(item, shop.Name)
            lastStock[getStockKey(shop.Name, item.Name)] = item.Value

            emit("SHOP", "ITEM", {
                ts = now(),
                cycle_id = cycleId,
                source = "ReplicatedStorage.StockValues",
                reason = reason,
                shop = shop.Name,
                item_name = item.Name,
                stock = item.Value,
                price = price,
                price_source = priceSource,
            })
        end
    end

    emit("SHOP", "BATCH_END", {
        ts = now(),
        cycle_id = cycleId,
        source = "ReplicatedStorage.StockValues",
        reason = reason,
        shop = shop.Name,
        items = count,
    })
end

local function emitStockValuesSnapshot(reason)
    local StockValues = RS:FindFirstChild("StockValues")

    if not StockValues then
        emit("SHOP", "STOCK_VALUES_NOT_FOUND", {
            ts = now(),
            reason = reason,
        })
        return
    end

    local cycleId = now()

    emit("SHOP", "STOCK_VALUES_SNAPSHOT_START", {
        ts = now(),
        cycle_id = cycleId,
        source = "ReplicatedStorage.StockValues",
        reason = reason,
    })

    for _, shop in ipairs(StockValues:GetChildren()) do
        if WATCH_SHOPS[shop.Name] then
            emitShopBatch(shop, reason)
        end
    end

    emit("SHOP", "STOCK_VALUES_SNAPSHOT_END", {
        ts = now(),
        cycle_id = cycleId,
        source = "ReplicatedStorage.StockValues",
        reason = reason,
    })
end

local function scheduleStockSnapshot(reason)
    if stockSnapshotPending then return end

    stockSnapshotPending = true

    task.delay(1, function()
        stockSnapshotPending = false
        emitStockValuesSnapshot(reason)
    end)
end

local function scheduleTimedRefreshSnapshot(reason)
    if not awaitingTimedRefresh then
        return
    end

    awaitingTimedRefresh = false

    scheduleStockSnapshot(reason)
end

local function hookStockItem(shopName, item)
    if not item:IsA("ValueBase") then return end

    local key = getStockKey(shopName, item.Name)
    lastStock[key] = item.Value

    local price, priceSource = getItemPrice(item, shopName)

    emit("SHOP", "WATCH_ITEM", {
        ts = now(),
        shop = shopName,
        item_name = item.Name,
        stock = item.Value,
        price = price,
        price_source = priceSource,
    })

    item:GetPropertyChangedSignal("Value"):Connect(function()
        local old = lastStock[key]
        local new = item.Value

        if old == new then return end

        lastStock[key] = new

        local changedPrice, changedPriceSource = getItemPrice(item, shopName)

        emit("SHOP", "VALUE_CHANGED", {
            ts = now(),
            source = "ReplicatedStorage.StockValues",
            shop = shopName,
            item_name = item.Name,
            old_stock = old,
            new_stock = new,
            price = changedPrice,
            price_source = changedPriceSource,
        })

        scheduleTimedRefreshSnapshot("timed_refresh_value_changed")
    end)
end

local function hookStockShop(shop)
    if not shop or not WATCH_SHOPS[shop.Name] then return end

    local items = shop:FindFirstChild("Items")
    if not items then
        emit("SHOP", "SHOP_NO_ITEMS_FOLDER", {
            ts = now(),
            shop = shop.Name,
        })
        return
    end

    emit("SHOP", "WATCH_SHOP", {
        ts = now(),
        shop = shop.Name,
        path = shop:GetFullName(),
    })

    for _, item in ipairs(items:GetChildren()) do
        hookStockItem(shop.Name, item)
    end

    items.ChildAdded:Connect(function(item)
        task.wait(0.1)

        if item:IsA("ValueBase") then
            local price, priceSource = getItemPrice(item, shop.Name)

            emit("SHOP", "ITEM_ADDED", {
                ts = now(),
                source = "ReplicatedStorage.StockValues",
                shop = shop.Name,
                item_name = item.Name,
                stock = item.Value,
                price = price,
                price_source = priceSource,
            })

            hookStockItem(shop.Name, item)
            scheduleTimedRefreshSnapshot("timed_refresh_item_added")
            scheduleStockSnapshot("stock_item_added")
        end
    end)

    items.ChildRemoved:Connect(function(item)
        emit("SHOP", "ITEM_REMOVED", {
            ts = now(),
            source = "ReplicatedStorage.StockValues",
            shop = shop.Name,
            item_name = item.Name,
            last_stock = lastStock[getStockKey(shop.Name, item.Name)],
        })

        lastStock[getStockKey(shop.Name, item.Name)] = nil
        scheduleTimedRefreshSnapshot("timed_refresh_item_removed")
        scheduleStockSnapshot("stock_item_removed")
    end)
end

local function hookStockValues()
    local StockValues = RS:FindFirstChild("StockValues")

    if not StockValues then
        emit("SHOP", "STOCK_VALUES_HOOK_FAILED", {
            ts = now(),
            missing = "ReplicatedStorage.StockValues",
        })
        return
    end

    for _, shop in ipairs(StockValues:GetChildren()) do
        hookStockShop(shop)
    end

    StockValues.ChildAdded:Connect(function(shop)
        task.wait(0.2)

        if WATCH_SHOPS[shop.Name] then
            emit("SHOP", "SHOP_ADDED", {
                ts = now(),
                shop = shop.Name,
                path = shop:GetFullName(),
            })

            hookStockShop(shop)
            scheduleTimedRefreshSnapshot("timed_refresh_shop_added")
            scheduleStockSnapshot("stock_shop_added")
        end
    end)

    StockValues.ChildRemoved:Connect(function(shop)
        if WATCH_SHOPS[shop.Name] then
            emit("SHOP", "SHOP_REMOVED", {
                ts = now(),
                shop = shop.Name,
            })

            scheduleTimedRefreshSnapshot("timed_refresh_shop_removed")
            scheduleStockSnapshot("stock_shop_removed")
        end
    end)

    emit("SHOP", "STOCK_VALUES_HOOK_READY", {
        ts = now(),
    })

    scheduleStockSnapshot("script_start_stock_snapshot")
end

local function getNextStockRefresh(ts)
    local remainder = ts % STOCK_REFRESH_INTERVAL
    local remaining = STOCK_REFRESH_INTERVAL - remainder

    if remaining == 0 then
        remaining = STOCK_REFRESH_INTERVAL
    end

    return ts + remaining, remaining
end

local function startStockRefreshLoop()
    task.spawn(function()
        local lastRefreshAt = nil

        while true do
            local ts = now()
            local nextRefreshTs, remaining = getNextStockRefresh(ts)

            emit("SYSTEM", "STOCK_RESTART_COUNTDOWN", {
                ts = ts,
                remaining_seconds = remaining,
                next_mark_ts = nextRefreshTs,
                interval_seconds = STOCK_REFRESH_INTERVAL,
                message = string.format("stock restart in %d:%02d", math.floor(remaining / 60), remaining % 60),
            })

            if remaining == 1 and lastRefreshAt ~= nextRefreshTs then
                lastRefreshAt = nextRefreshTs
                awaitingTimedRefresh = true
                awaitedRefreshMark = nextRefreshTs

                emit("SYSTEM", "STOCK_REFRESH_WAITING", {
                    ts = ts,
                    refresh_mark_ts = nextRefreshTs,
                    message = "waiting for real stock update after five-minute mark",
                })
            end

            task.wait(1)
        end
    end)
end

