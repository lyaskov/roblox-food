local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local ReplicaSet = RemoteEvents:WaitForChild("ReplicaSet")

local MAX_DEPTH = 6

local function printTable(value, indent, depth)
    indent = indent or ""
    depth = depth or 0

    if depth > MAX_DEPTH then
        print(indent .. "...MAX_DEPTH")
        return
    end

    if typeof(value) ~= "table" then
        print(indent .. tostring(value))
        return
    end

    local empty = true

    for k, v in pairs(value) do
        empty = false

        if typeof(v) == "table" then
            print(indent .. tostring(k) .. " = {")
            printTable(v, indent .. "  ", depth + 1)
            print(indent .. "}")
        else
            print(indent .. tostring(k) .. " = " .. tostring(v))
        end
    end

    if empty then
        print(indent .. "{}")
    end
end

ReplicaSet.OnClientEvent:Connect(function(...)
    local args = { ... }

    print("")
    print("========== REPLICA_SET ==========")

    for i, v in ipairs(args) do
        print("ARG_" .. i .. " TYPE = " .. typeof(v))

        if typeof(v) == "table" then
            printTable(v, "  ", 0)
        else
            print("  " .. tostring(v))
        end
    end

    print("========== END ==========")
end)

