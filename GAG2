-- =========================
-- LIVE PETS
-- =========================

local function snapshotPets()
    local result = {
        WildPetRef = {},
        WildPetSpawns = {},
        PlayerPetReferences = {},
    }

    local map = workspace:FindFirstChild("Map")

    if map then
        local wildPetRef = map:FindFirstChild("WildPetRef")
        if wildPetRef then
            for _, obj in ipairs(wildPetRef:GetChildren()) do
                table.insert(result.WildPetRef, {
                    Name = obj.Name,
                    ClassName = obj.ClassName,
                    Attributes = obj:GetAttributes(),
                })
            end
        end

        local wildPetSpawns = map:FindFirstChild("WildPetSpawns")
        if wildPetSpawns then
            for _, obj in ipairs(wildPetSpawns:GetChildren()) do
                table.insert(result.WildPetSpawns, {
                    Name = obj.Name,
                    ClassName = obj.ClassName,
                    Attributes = obj:GetAttributes(),
                })
            end
        end
    end

    local refs = workspace:FindFirstChild("PlayerPetReferences")
    if refs then
        for _, folder in ipairs(refs:GetChildren()) do
            result.PlayerPetReferences[folder.Name] = {}

            for _, obj in ipairs(folder:GetChildren()) do
                table.insert(result.PlayerPetReferences[folder.Name], {
                    Name = obj.Name,
                    ClassName = obj.ClassName,
                    Attributes = obj:GetAttributes(),
                })
            end
        end
    end

    log("PETS", result)
end

local function hookPets()
    local map = workspace:FindFirstChild("Map")

    if map then
        local wildPetRef = map:FindFirstChild("WildPetRef")
        if wildPetRef then
            wildPetRef.ChildAdded:Connect(snapshotPets)
            wildPetRef.ChildRemoved:Connect(snapshotPets)
        end

        local wildPetSpawns = map:FindFirstChild("WildPetSpawns")
        if wildPetSpawns then
            wildPetSpawns.ChildAdded:Connect(snapshotPets)
            wildPetSpawns.ChildRemoved:Connect(snapshotPets)
        end
    end

    local refs = workspace:FindFirstChild("PlayerPetReferences")
    if refs then
        refs.DescendantAdded:Connect(snapshotPets)
        refs.DescendantRemoving:Connect(snapshotPets)
    end

    warn("PETS_HOOK|READY")
    snapshotPets()
end

-- =========================
-- OPTIONAL: RESTOCK NOTIFICATION
-- =========================

local function hookReplicaRestockSignal()
    local remoteEvents = RS:FindFirstChild("RemoteEvents")
    if not remoteEvents then return end

    local replicaSet = remoteEvents:FindFirstChild("ReplicaSet")
    if not replicaSet then return end

    replicaSet.OnClientEvent:Connect(function(replicaId, path, value)
        if typeof(path) == "table" and path[1] == "PurchasedThisRestock" then
            warn("RESTOCK_SIGNAL|" .. tostring(path[2]))
            delayedStock()
        end
    end)

    warn("RESTOCK_SIGNAL_HOOK|READY")
end

