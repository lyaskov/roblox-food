local RS = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local LOG_PREFIX = "GAG2"
local MAX_LEN = 800
local DISCOVERY_MODE = true
local emitSequence = 0

local function now()
    return os.time()
end

local function nextMessageId(tag, kind)
    emitSequence += 1
    return tostring(now()) .. "_" .. tostring(emitSequence) .. "_" .. tostring(tag) .. "_" .. tostring(kind)
end

local function emit(tag, kind, payload)
    payload = payload or {}

    local ok, json = pcall(function()
        return HttpService:JSONEncode(payload)
    end)

    if not ok then
        json = HttpService:JSONEncode({
            error = "JSON_ENCODE_FAILED",
            value = tostring(payload),
        })
    end

    if #json <= MAX_LEN then
        warn(LOG_PREFIX .. "|" .. tag .. "|" .. kind .. "|" .. json)
        return
    end

    local total = math.ceil(#json / MAX_LEN)
    local messageId = nextMessageId(tag, kind)

    for i = 1, total do
        local startIndex = ((i - 1) * MAX_LEN) + 1
        local part = string.sub(json, startIndex, startIndex + MAX_LEN - 1)

        warn(LOG_PREFIX .. "|" .. tag .. "|" .. kind .. "_PART|" .. messageId .. "|" .. i .. "/" .. total .. "|" .. part)
    end
end

local function toSimple(value, depth)
    depth = depth or 0
    if depth > 5 then return "..." end

    local t = typeof(value)

    if value == nil then
        return nil
    elseif t == "string" or t == "number" or t == "boolean" then
        return value
    elseif t == "Vector3" then
        return { type = "Vector3", x = value.X, y = value.Y, z = value.Z }
    elseif t == "CFrame" then
        local p = value.Position
        return { type = "CFrame", x = p.X, y = p.Y, z = p.Z }
    elseif t == "Color3" then
        return { type = "Color3", r = value.R, g = value.G, b = value.B }
    elseif t == "Instance" then
        return {
            type = "Instance",
            class = value.ClassName,
            name = value.Name,
            path = value:GetFullName(),
        }
    elseif type(value) == "table" then
        local result = {}
        local count = 0

        for k, v in pairs(value) do
            count += 1
            result[tostring(k)] = toSimple(v, depth + 1)

            if count >= 80 then
                result.__truncated = true
                break
            end
        end

        return result
    end

    return tostring(value)
end

local function getValue(obj)
    if obj and obj:IsA("ValueBase") then
        return obj.Value
    end

    return nil
end

